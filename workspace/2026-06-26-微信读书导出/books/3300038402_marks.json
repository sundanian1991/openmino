{"synckey":1684820533,"updated":[{"bookId":"3300038402","bookmarkId":"3300038402_16_748-897","createTime":1684820533,"chapterUid":16,"colorStyle":2,"type":1,"markText":"在思想文化的领域里边，我们向西方也学习了一百多年了。这一百多年来向西方学习，对中国的进步有很大的意义。这个进步，它的标准是西方设定的，因为我们是被迫进入现代化的国家。现代化的首要目标，就是工业化；工业化的前提，就是必须引入市场原则，引入资本的逻辑。","range":"748-897"}],"removed":[],"chapters":[{"title":"中西方文化差异的渊源","chapterUid":16,"chapterIdx":3}],"book":{"bookId":"3300038402","version":953522812,"format":"epub","soldout":0,"bookStatus":1,"cover":"https://cdn.weread.qq.com/weread/cover/86/cpPlatform_dBA8CcERMXPBuGgTkn8zF2/s_cpPlatform_dBA8CcERMXPBuGgTkn8zF2.jpg","title":"寻觅意义","author":"王德峰","coverBoxInfo":{"blurhash":"KpEDJFbHof02Rjj[^*ofay","colors":[{"key":"1/4","hex":"#0b1c35"},{"key":"1/6","hex":"#001c41"},{"key":"1/8","hex":"#001b4d"},{"key":"2/4","hex":"#21314b"},{"key":"2/6","hex":"#113158"},{"key":"2/8","hex":"#003165"},{"key":"3/4","hex":"#374864"},{"key":"3/6","hex":"#2a4872"},{"key":"3/8","hex":"#16487e"},{"key":"3/12","hex":"#004898"},{"key":"4/6","hex":"#476189"},{"key":"4/10","hex":"#2161a3"},{"key":"4/4","hex":"#51617b"},{"key":"5/10","hex":"#437bbd"},{"key":"5/4","hex":"#6b7a94"},{"key":"5/8","hex":"#547bb0"},{"key":"6/4","hex":"#8594ad"},{"key":"6/6","hex":"#7b95bc"},{"key":"6/8","hex":"#6f95ca"},{"key":"6/12","hex":"#4896e8"},{"key":"7/8","hex":"#88b0e5"},{"key":"7/10","hex":"#77b0f6"},{"key":"7/12","hex":"#5eb1ff"},{"key":"8/4","hex":"#b8c9e2"},{"key":"8/6","hex":"#abcaf4"},{"key":"8/12","hex":"#79ccff"},{"key":"9/2","hex":"#dde4ed"},{"key":"9/12","hex":"#8fe8ff"},{"key":"1/100","hex":"#6f95ca"},{"key":"2/100","hex":"#88b0e5"},{"key":"3/100","hex":"#ffffff"},{"key":"4/100","hex":"#E5ECF3"},{"key":"5/100","hex":"#E5ECF3"},{"key":"6/100","hex":"#001927"}],"dominate_color":{"hex":"#104e8a","hsv":[209.35783902187496,88.64989059080964,53.92499604380734]},"custom_cover":"https://weread-1258476243.file.myqcloud.com/bookalphacover/402/3300038402/s_3300038402.jpg","custom_rec_cover":"https://weread-1258476243.f