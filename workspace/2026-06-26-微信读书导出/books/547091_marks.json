{"synckey":1572600843,"updated":[{"bookId":"547091","bookmarkId":"547091_37_1948-2087","chapterUid":37,"markText":"想要解决烦恼，不论是生活中的小烦恼，或是事业失败、亲人死亡的大烦恼，乃至于死亡的究竟烦恼，一定得先生起“觉性”，也就是认出心中那一个不动的自己，然后通过“觉”，一步一步地深入认识烦恼的运作方式，它的起承转合，它的成住坏空，再进而认出它空性的本质，最后能够骑乘甚至运用烦恼的能量。","range":"1948-2087","createTime":1572600843,"type":1}],"removed":[],"chapters":[{"title":"念完阿弥陀佛回归觉性科学","chapterUid":37,"chapterIdx":12}],"book":{"bookId":"547091","version":0,"format":"txt","soldout":0,"bookStatus":1,"cover":"https://cdn.weread.qq.com/weread/cover/96/YueWen_547091/s_YueWen_547091.jpg","title":"念完哈佛念阿弥陀佛","author":"陈宇廷","coverBoxInfo":{"blurhash":"KJBqk*Mly1VF%bD+.bnipH","colors":[{"key":"1/4","hex":"#00230f"},{"key":"1/6","hex":"#002606"},{"key":"1/8","hex":"#002800"},{"key":"2/4","hex":"#183723"},{"key":"2/6","hex":"#003a1b"},{"key":"2/8","hex":"#003c12"},{"key":"3/4","hex":"#2d4f36"},{"key":"3/6","hex":"#16522c"},{"key":"3/8","hex":"#005523"},{"key":"3/12","hex":"#00590b"},{"key":"4/6","hex":"#2f6c40"},{"key":"4/10","hex":"#007228"},{"key":"4/4","hex":"#44694b"},{"key":"5/10","hex":"#008d3f"},{"key":"5/4","hex":"#5d8363"},{"key":"5/8","hex":"#348a4b"},{"key":"6/4","hex":"#759d7a"},{"key":"6/6","hex":"#65a16e"},{"key":"6/8","hex":"#51a562"},{"key":"6/12","hex":"#00ab49"},{"key":"7/8","hex":"#6dc07a"},{"key":"7/10","hex":"#56c36c"},{"key":"7/12","hex":"#35c75f"},{"key":"8/4","hex":"#a8d3ab"},{"key":"8/6","hex":"#97d79d"},{"key":"8/12","hex":"#56e374"},{"key":"9/2","hex":"#d0ead1"},{"key":"9/12","hex":"#6fff89"},{"key":"1/100","hex":"#51a562"},{"key":"2/100","hex":"#6dc07a"},{"key":"3/100","hex":"#ffffff"},{"key":"4/100","hex":"#E5F3E9"},{"key":"5/100","hex":"#E5F3E9"},{"key":"6/100","hex":"#002706"}],"dominate_color":{"hex":"#3f704a","hsv":[133.34093757942328,43.51620754044017,43.92656777794096]},"custom_cover":"https://weread-1258476243.file.myqcloud.com/bookalphacover/91/547091/s_547091.jpg","custom_rec_cover":"https://weread-1258476243.file.myqcloud.com/bookreccover/91/547091/s_547091.jpg","col