{"synckey":1661530154,"updated":[{"bookId":"3300026042","bookmarkId":"3300026042_5_1342-1511","chapterUid":5,"markText":"对于年度市场计划来说，不管是从战略到战术的计划，还是直接列具体执行项目的计划，都需要花费不少精力和时间。最让人痛心的是，做好了计划却发现很多文档、表格在汇报后就不再被打开了。具体落地时，市场部门该怎么做还怎么做，要么临时做计划、报审批，要么直接听领导和销售负责人的建议，甚至临时发起赞助或参加活动也是常有的事。这就成了典型的为计划而计划。","range":"1342-1511","createTime":1661530154,"type":1},{"bookId":"3300026042","bookmarkId":"3300026042_5_805-842","chapterUid":5,"markText":"做计划就是走形式，到了具体要执行的时候，不是没费用，就是“计划不如变化快”","range":"805-842","createTime":1661530121,"type":1}],"removed":[],"chapters":[{"title":"营销篇","chapterUid":5,"chapterIdx":5}],"book":{"bookId":"3300026042","version":2062050145,"format":"epub","soldout":0,"bookStatus":1,"cover":"https://cdn.weread.qq.com/weread/cover/47/cpPlatform_gXSsuTPcEr7vXyq3Fs2jZG/s_cpPlatform_gXSsuTPcEr7vXyq3Fs2jZG.jpg","title":"To B增长实战：获客、营销、运营与管理","author":"朱强 鲁扬 彭罕妮","coverBoxInfo":{"blurhash":"K7R3TX4ooe00?b-;nzadt8","colors":[{"key":"1/4","hex":"#101b35"},{"key":"1/6","hex":"#041a41"},{"key":"1/8","hex":"#00194c"},{"key":"2/4","hex":"#25304b"},{"key":"2/6","hex":"#1b3058"},{"key":"2/8","hex":"#092f65"},{"key":"3/4","hex":"#3b4765"},{"key":"3/6","hex":"#314772"},{"key":"3/8","hex":"#26467e"},{"key":"3/12","hex":"#004598"},{"key":"4/6","hex":"#4c6089"},{"key":"4/10","hex":"#345fa3"},{"key":"4/4","hex":"#55607c"},{"key":"5/10","hex":"#5179bd"},{"key":"5/4","hex":"#6e7994"},{"key":"5/8","hex":"#5d79b0"},{"key":"6/4","hex":"#8894ad"},{"key":"6/6","hex":"#8094bc"},{"key":"6/8","hex":"#7794ca"},{"key":"6/12","hex":"#5c93e8"},{"key":"7/8","hex":"#8faee6"},{"key":"7/10","hex":"#83aef7"},{"key":"7/12","hex":"#72aeff"},{"key":"8/4","hex":"#bbc8e2"},{"key":"8/6","hex":"#b0c9f4"},{"key":"8/12","hex":"#8bc9ff"},{"key":"9/2","hex":"#dee3ed"},{"key":"9/12","hex":"#a2e4ff"},{"key":"1/100","hex":"#7794ca"},{"key":"2/100","hex":"#8faee6"},{"key":"3/100","hex":"#ffffff"},{"key":"4/100","hex":"#E5ECF3"},{"key":"5/100","hex":"#E5ECF3"},{"key":"6/100","hex":"#001927"}],"dominate_color":{"hex":"#024