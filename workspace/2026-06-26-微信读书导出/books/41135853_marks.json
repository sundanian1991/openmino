{"synckey":1651316137,"updated":[{"bookId":"41135853","bookmarkId":"41135853_5_1832-1981","chapterUid":5,"markText":"为了通过一些重要的决议，把太多人员聚集到大会议室里，分发的资料简直厚到读不完。开会时，除了进行陈述和答疑的人之外，发言的只有少数几个人，通常是位高权重的领导。经过一番讨论之后，还是无法做出决定，只能留待下次再议。浪费了大量时间，却毫无收获地离开了会议室，心里掂量着是不是下个月还得再经历这么一次……","range":"1832-1981","createTime":1651316137,"type":1},{"bookId":"41135853","bookmarkId":"41135853_15_1115-1159","chapterUid":15,"markText":"项目的背景、主旨、对应的行动计划，以及最后想达成的目标，都要简明扼要地写在1张A4纸上。","range":"1115-1159","createTime":1651316048,"type":1}],"removed":[],"chapters":[{"title":"前言 为什么要学习亚马逊的开会方法？","chapterUid":5,"chapterIdx":5},{"title":"3 “1页纸”","chapterUid":15,"chapterIdx":15}],"book":{"bookId":"41135853","version":532224544,"format":"epub","soldout":0,"bookStatus":1,"cover":"https://cdn.weread.qq.com/weread/cover/48/YueWen_41135853/s_YueWen_41135853.jpg","title":"贝佐斯如何开会","author":"佐藤将之","coverBoxInfo":{"blurhash":"KDOU^aIq~A58j[%0-.jsRk","colors":[{"key":"1/4","hex":"#331400"},{"key":"1/6","hex":"#3a0f00"},{"key":"1/8","hex":"#410600"},{"key":"2/4","hex":"#462b10"},{"key":"2/6","hex":"#4d2700"},{"key":"2/8","hex":"#522500"},{"key":"3/4","hex":"#604125"},{"key":"3/6","hex":"#673e0f"},{"key":"3/8","hex":"#6c3c00"},{"key":"3/12","hex":"#763600"},{"key":"4/6","hex":"#835626"},{"key":"4/10","hex":"#8e5200"},{"key":"4/4","hex":"#7b5939"},{"key":"5/10","hex":"#ac6b00"},{"key":"5/4","hex":"#957352"},{"key":"5/8","hex":"#a76d24"},{"key":"6/4","hex":"#b08d6b"},{"key":"6/6","hex":"#ba8a56"},{"key":"6/8","hex":"#c3873e"},{"key":"6/12","hex":"#cf8200"},{"key":"7/8","hex":"#dfa158"},{"key":"7/10","hex":"#e79f3e"},{"key":"7/12","hex":"#ee9c18"},{"key":"8/4","hex":"#e5c29c"},{"key":"8/6","hex":"#f1bf87"},{"key":"8/12","hex":"#ffb738"},{"key":"9/2","hex":"#f3e0cb"},{"key":"9/12","hex":"#ffd253"},{"key":"1/100","hex":"#c3873e"},{"key":"2/100","hex":"#dfa158"},{"key":"3/100","hex":"#ffffff"},{"key":"4/100","hex":"#F3EDE5"},{"key":"5/100","hex":"#F3EDE5"},{"key":"6/100","hex":"#271300"}],"dominate_color":{"hex":"#e0af79",