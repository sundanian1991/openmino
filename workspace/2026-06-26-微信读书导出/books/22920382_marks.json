{"synckey":1735113964,"updated":[{"bookId":"22920382","bookmarkId":"22920382_9_5311-5357","chapterUid":69,"markText":"我们根据AARRR增长模型（图2-2），将产品的营收路径拆分为激活→注册→留存→下单→传播。","range":"5264-5310","createTime":1585921784,"type":1},{"bookId":"22920382","bookmarkId":"22920382_9_2819-3018","chapterUid":69,"markText":"平台的表现主要从流量来源、产品本身、运营策略及竞品角度来展开。流量来源上，我们需要分析流量的渠道质量，在时间维度上是否有变更；产品上，看是否近期有调整，比如是否调整了入口，调整了搜索逻辑等，这些调整对转化节点的转化率的影响如何等；运营策略上，看近期的运营活动对客单价的影响路径如何，近期竞品是否有做什么活动吸引了目标用户。每一个可能的原因都可以做成一个小专题分析。下面再聚焦回来看对客单价的影响情况","range":"2766-2965","createTime":1585921684,"type":1}],"removed":[],"chapters":[{"title":"第2章 业务：数据驱动运营","chapterUid":69,"chapterIdx":10}],"book":{"bookId":"22920382","version":993176857,"format":"epub","soldout":0,"bookStatus":1,"cover":"https://cdn.weread.qq.com/weread/cover/6/yuewen_22920382/s_yuewen_229203821735113901.jpg","title":"数据化运营：系统方法与实践案例","author":"赵宏田 江丽萍 李宁","coverBoxInfo":{"blurhash":"KAR3J:o0.jQ.RkXRbpbbje","colors":[{"key":"1/4","hex":"#192000"},{"key":"1/6","hex":"#172000"},{"key":"1/8","hex":"#162100"},{"key":"2/4","hex":"#2f340c"},{"key":"2/6","hex":"#2c3500"},{"key":"2/8","hex":"#293700"},{"key":"3/4","hex":"#464b1f"},{"key":"3/6","hex":"#454c00"},{"key":"3/8","hex":"#434d00"},{"key":"3/12","hex":"#3e4f00"},{"key":"4/6","hex":"#5e6517"},{"key":"4/10","hex":"#5b6700"},{"key":"4/4","hex":"#5f6433"},{"key":"5/10","hex":"#768100"},{"key":"5/4","hex":"#787e4b"},{"key":"5/8","hex":"#778002"},{"key":"6/4","hex":"#939862"},{"key":"6/6","hex":"#929948"},{"key":"6/8","hex":"#919b25"},{"key":"6/12","hex":"#909c00"},{"key":"7/8","hex":"#acb543"},{"key":"7/10","hex":"#abb60f"},{"key":"7/12","hex":"#abb700"},{"key":"8/4","hex":"#c8cc92"},{"key":"8/6","hex":"#c8ce77"},{"key":"8/12","hex":"#c6d200"},{"key":"9/2","hex":"#e4e6c3"},{"key":"9/12","hex":"#e1ee15"},{"key":"1/100","hex":"#919b25"},{"key":"2/100","hex":"#acb543"},{"key":"3/100","hex":"#ffffff"},{"key":"4/100","hex":"#F3F1E5"},{"key":"5/100","hex":"#F3F1E5"},{"key":"6/100","hex":"#271E00"}],"dominate_colo