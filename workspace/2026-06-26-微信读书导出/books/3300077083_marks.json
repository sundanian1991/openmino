{"synckey":1702615649,"updated":[{"bookId":"3300077083","bookmarkId":"3300077083_6_9256-9355","createTime":1702509676,"chapterUid":6,"colorStyle":3,"type":1,"markText":"地图一般由两种分解方式组成，一种是框架（纵向分解），一种是因数分解（横向分解）。","range":"9256-9355"},{"bookId":"3300077083","bookmarkId":"3300077083_6_6802-7120","createTime":1702509530,"chapterUid":6,"colorStyle":3,"type":1,"markText":"解决问题的人在解决问题前，也必须记住框架。从头推导公式是非常困难的，从头制定框架亦是如此。牢记固定的框架就像是找到了思考的捷径，以此来提高效率。从这层意义上来讲，“框架手账”就相当于考前学生随身携带的装满了公式的参考书。","range":"6802-7120"},{"bookId":"3300077083","bookmarkId":"3300077083_6_7279-7362","createTime":1702509517,"chapterUid":6,"colorStyle":3,"type":1,"markText":"解决问题的人必须使用框架分解问题，找到问题的症结（瓶颈）所在。","range":"7279-7362"}],"removed":[],"chapters":[{"title":"第2章 案例分析问题的5个步骤","chapterUid":6,"chapterIdx":6}],"book":{"bookId":"3300077083","version":667068324,"format":"epub","soldout":1,"bookStatus":1,"cover":"https://cdn.weread.qq.com/weread/cover/78/cpplatform_u39bvkpqfawrojsmuuiugj/s_cpplatform_u39bvkpqfawrojsmuuiugj1699350159.jpg","title":"聪明人都用框架找答案","author":"日本东大案例学习研究会","coverBoxInfo":{"blurhash":"K7Bq0_M{H?tk5GwZE9sT}%","colors":[{"key":"1/4","hex":"#0f1c35"},{"key":"1/6","hex":"#011b41"},{"key":"1/8","hex":"#001a4d"},{"key":"2/4","hex":"#24304b"},{"key":"2/6","hex":"#183058"},{"key":"2/8","hex":"#002f65"},{"key":"3/4","hex":"#394765"},{"key":"3/6","hex":"#2f4772"},{"key":"3/8","hex":"#21477e"},{"key":"3/12","hex":"#004698"},{"key":"4/6","hex":"#4a6089"},{"key":"4/10","hex":"#2f60a3"},{"key":"4/4","hex":"#53607c"},{"key":"5/10","hex":"#4d7abd"},{"key":"5/4","hex":"#6d7a94"},{"key":"5/8","hex":"#5a7ab0"},{"key":"6/4","hex":"#8794ad"},{"key":"6/6","hex":"#7e94bc"},{"key":"6/8","hex":"#7494ca"},{"key":"6/12","hex":"#5694e8"},{"key":"7/8","hex":"#8dafe6"},{"key":"7/10","hex":"#7faff7"},{"key":"7/12","hex":"#6cafff"},{"key":"8/4","hex":"#bac9e2"},{"key":"8/6","hex":"#afc9f4"},{"key":"8/12","hex":"#86caff"},{"key":"9/2","hex":"#dde3ed"},{"key":"9/12","hex":"#9ce5ff"},{"key":"1/100","hex":"#7494ca"},{"key":"2