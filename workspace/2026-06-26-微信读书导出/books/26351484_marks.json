{"synckey":1689741598,"updated":[{"bookId":"26351484","bookmarkId":"26351484_13_3619-3711","createTime":1689741598,"chapterUid":13,"colorStyle":2,"type":1,"markText":"第一，脚掌不要用力蹬地，以“轻轻往后蹬”的感觉移动即可。第二，双手不要大幅摆动，轻轻放在身体两侧摆动，保持平衡就可以。","range":"3619-3711"},{"bookId":"26351484","bookmarkId":"26351484_14_1808-2314","chapterUid":14,"markText":"有效率的跑步姿势1．将两只手放在胯骨最上方的位置，接着想象该处被线往前拉的感觉，交互踏出双腿。2．这时使用的是臀部与大腿内侧的肌肉，腰部会自然往前推，这就是最轻松的跑步姿势。3．双手微弯，保持一定节奏，以手肘带动手臂，自然来回摆动。4．双手不要用力往前摆动，否则会让身体因为反作用力而往后倾，造成反效果。","range":"1808-2314","createTime":1652008758,"type":1}],"removed":[],"chapters":[{"title":"02 小步、定速，就这么简单","chapterUid":13,"chapterIdx":13},{"title":"03 最轻松的跑步姿势大公开","chapterUid":14,"chapterIdx":14}],"book":{"bookId":"26351484","version":788825921,"format":"epub","soldout":0,"bookStatus":1,"cover":"https://wfqqreader-1252317822.image.myqcloud.com/cover/484/26351484/s_26351484.jpg","title":"惊人的超慢跑","author":"梅方久仁子","coverBoxInfo":{"blurhash":"KqL#g;w|ScIoNFs:_4ogV@","colors":[{"key":"1/4","hex":"#002310"},{"key":"1/6","hex":"#002607"},{"key":"1/8","hex":"#002801"},{"key":"2/4","hex":"#173724"},{"key":"2/6","hex":"#003a1c"},{"key":"2/8","hex":"#003c15"},{"key":"3/4","hex":"#2b4f37"},{"key":"3/6","hex":"#12522e"},{"key":"3/8","hex":"#005526"},{"key":"3/12","hex":"#005a14"},{"key":"4/6","hex":"#2b6d42"},{"key":"4/10","hex":"#00732e"},{"key":"4/4","hex":"#42694d"},{"key":"5/10","hex":"#008d44"},{"key":"5/4","hex":"#5c8364"},{"key":"5/8","hex":"#2e8a4f"},{"key":"6/4","hex":"#749d7c"},{"key":"6/6","hex":"#63a171"},{"key":"6/8","hex":"#4da565"},{"key":"6/12","hex":"#00ac4f"},{"key":"7/8","hex":"#6ac07d"},{"key":"7/10","hex":"#50c471"},{"key":"7/12","hex":"#27c764"},{"key":"8/4","hex":"#a7d3ac"},{"key":"8/6","hex":"#95d89f"},{"key":"8/12","hex":"#4de37a"},{"key":"9/2","hex":"#d0ead2"},{"key":"9/12","hex":"#67ff8f"},{"key":"1/100","hex":"#4da565"},{"key":"2/100","hex":"#6ac07d"},{"key":"3/100","hex":"#ffffff"},{"key":"4/100","hex":"#E5F3E9"},{"key":"5/100","hex":"#E5F3E9"},{"key":"6/100","hex":"#0