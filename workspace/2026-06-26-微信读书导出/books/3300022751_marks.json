{"synckey":1723422222,"updated":[{"bookId":"3300022751","bookmarkId":"3300022751_5_3836-4017","createTime":1723422222,"chapterUid":5,"colorStyle":3,"type":1,"markText":"在墙上形成黄颜色的那么一道痕迹，这本来是古代人所用的一种比喻，是说写字不要把笔毛起止的痕迹都给人看得那么清楚，你下笔怎么描、怎么圈、怎么转折，让人看着很自然就那么一道下来，仿佛你都看不见开始那笔道是怎么写的，收笔的时候是怎么收，就是自然的那么一道，像旧房子漏了雨，在墙上留下水的痕迹一样。这古代的“屋漏痕”只不过是个比喻，说写字的笔画要纯出自然，没有描摹的痕迹。","range":"3836-4017"}],"removed":[],"chapters":[{"title":"迷信由于误解","chapterUid":5,"chapterIdx":5}],"book":{"bookId":"3300022751","version":177787478,"format":"epub","soldout":0,"bookStatus":1,"cover":"https://cdn.weread.qq.com/weread/cover/51/3300022751/s_3300022751.jpg","title":"学习书法的十三个问题（湖山艺丛）","author":"启功","coverBoxInfo":{"blurhash":"K2SY:N^d%MSiogt6~qIqMx","colors":[{"key":"1/4","hex":"#1f1c19"},{"key":"1/6","hex":"#1f1c19"},{"key":"1/8","hex":"#1f1c19"},{"key":"2/4","hex":"#33302e"},{"key":"2/6","hex":"#33302e"},{"key":"2/8","hex":"#33302e"},{"key":"3/4","hex":"#4a4744"},{"key":"3/6","hex":"#4a4744"},{"key":"3/8","hex":"#4a4744"},{"key":"3/12","hex":"#4a4744"},{"key":"4/6","hex":"#63605c"},{"key":"4/10","hex":"#63605c"},{"key":"4/4","hex":"#63605c"},{"key":"5/10","hex":"#7c7976"},{"key":"5/4","hex":"#7c7976"},{"key":"5/8","hex":"#7c7976"},{"key":"6/4","hex":"#96938f"},{"key":"6/6","hex":"#96938f"},{"key":"6/8","hex":"#96938f"},{"key":"6/12","hex":"#96938f"},{"key":"7/8","hex":"#b0ada9"},{"key":"7/10","hex":"#b0ada9"},{"key":"7/12","hex":"#b0ada9"},{"key":"8/4","hex":"#cac7c3"},{"key":"8/6","hex":"#cac7c3"},{"key":"8/12","hex":"#cac7c3"},{"key":"9/2","hex":"#e6e3de"},{"key":"9/12","hex":"#e6e3de"},{"key":"1/100","hex":"#96938f"},{"key":"2/100","hex":"#b0ada9"},{"key":"3/100","hex":"#ffffff"},{"key":"4/100","hex":"#F3EDE5"},{"key":"5/100","hex":"#F3EDE5"},{"key":"6/100","hex":"#271300"}],"dominate_color":{"hex":"#f6f3ee","hsv":[38.94096373331014,2.9507645711752978,96.35945925980646]},"custom_cover":"https://weread-1258476243.file.myqcloud.com/bookalphacover/751/3300022751/s_3300022751.jpg","custom_rec_cover":"https://