{"synckey":1654734055,"updated":[{"bookId":"40638606","bookmarkId":"40638606_6_8108-8155","chapterUid":6,"markText":"在学校走廊里，你可能会发现自己嘴上说着应该做某件事，但内心深处却想做别的事：去教室，回扫帚柜。","range":"8108-8155","createTime":1654734055,"type":1},{"bookId":"40638606","bookmarkId":"40638606_6_7941-7954","chapterUid":6,"markText":"亲缘主义者。","range":"7941-7954","createTime":1654734028,"type":1},{"bookId":"40638606","bookmarkId":"40638606_6_3419-3543","chapterUid":6,"markText":"事实证明，我们并不完全是孤身一人。我们的身体里携带着许多进化而来的模块，在一些重要的方面，我们是这些模块影响下的决策的集合。我们把这些模块称为“类型”，记住，这是一个概念：一种试图理解复杂过程的方法。它不是对世界的精确描述，而是思考世界的一种方式。","range":"3419-3543","createTime":1654733492,"type":1},{"bookId":"40638606","bookmarkId":"40638606_6_2786-2819","chapterUid":6,"markText":"帮助解决人类生活中反复出现的一些关键问题。这就是“模块化”的概念。","range":"2786-2819","createTime":1654733469,"type":1}],"removed":[],"chapters":[{"title":"序言","chapterUid":6,"chapterIdx":6}],"book":{"bookId":"40638606","version":1970084753,"format":"epub","soldout":0,"bookStatus":1,"cover":"https://cdn.weread.qq.com/weread/cover/45/YueWen_40638606/s_YueWen_40638606.jpg","title":"十种人性","author":"德克斯特·迪亚斯","coverBoxInfo":{"blurhash":"KlPi@dR.o#o#oJWB%%t6V@","colors":[{"key":"1/4","hex":"#2a1900"},{"key":"1/6","hex":"#301800"},{"key":"1/8","hex":"#351600"},{"key":"2/4","hex":"#3e2f05"},{"key":"2/6","hex":"#432d00"},{"key":"2/8","hex":"#472c00"},{"key":"3/4","hex":"#56461e"},{"key":"3/6","hex":"#5b4500"},{"key":"3/8","hex":"#5e4400"},{"key":"3/12","hex":"#644200"},{"key":"4/6","hex":"#755d17"},{"key":"4/10","hex":"#7b5c00"},{"key":"4/4","hex":"#705e31"},{"key":"5/10","hex":"#987500"},{"key":"5/4","hex":"#8a7849"},{"key":"5/8","hex":"#957607"},{"key":"6/4","hex":"#a49261"},{"key":"6/6","hex":"#ab9146"},{"key":"6/8","hex":"#b09027"},{"key":"6/12","hex":"#b78f00"},{"key":"7/8","hex":"#cbab44"},{"key":"7/10","hex":"#d0aa1a"},{"key":"7/12","hex":"#d3a900"},{"key":"8/4","hex":"#d9c792"},{"key":"8/6","hex":"#e0c678"},{"key":"8/12","hex":"#efc400"},{"key":"9/2","hex":"#ede3c4"},{"key":"9/12","hex":"#ffe02a"