{"synckey":1714151170,"updated":[{"bookId":"3300075734","bookmarkId":"3300075734_4_842-940","createTime":1698555374,"chapterUid":52,"colorStyle":3,"type":1,"markText":"本来他们只是晋国的家臣，没有资格当诸侯，但是他们从当时的周天子周威烈王那里得到了诸侯的名分，这在周朝历史上是前所未有的。这导致“春秋五霸”之一的晋国消失了，“战国七雄”中的韩、赵、魏三国冉冉升起。","range":"700-798"},{"bookId":"3300075734","bookmarkId":"3300075734_3_3936-4026","createTime":1698555315,"chapterUid":50,"colorStyle":3,"type":1,"markText":"“读书切戒在慌忙，涵泳工夫兴味长。未晓不妨权放过，切身须要急思量。”别着急、慢慢读，读到自己有感触的地方，停下来想想。读到不懂的地方，似乎又没有那么重要的，把它放过去，不必求甚解。","range":"3922-4012"}],"removed":[],"chapters":[{"title":"三家分晋：管理体系中最重要的是秩序","chapterUid":52,"chapterIdx":5},{"title":"序言 读透《资治通鉴》，过好在地球上的一生","chapterUid":50,"chapterIdx":3}],"book":{"bookId":"3300075734","version":785409798,"format":"epub","soldout":0,"bookStatus":1,"cover":"https://cdn.weread.qq.com/weread/cover/28/cpplatform_xgrohdjxudscwy9a5ejycb/s_cpplatform_xgrohdjxudscwy9a5ejycb1698391576.jpg","title":"胜者心法：资治通鉴成事之道","author":"冯唐","coverBoxInfo":{"blurhash":"KmGT8hoLNI0OayWC%KayxZ","colors":[{"key":"1/4","hex":"#0d1c35"},{"key":"1/6","hex":"#001b41"},{"key":"1/8","hex":"#001a4d"},{"key":"2/4","hex":"#23314b"},{"key":"2/6","hex":"#153158"},{"key":"2/8","hex":"#003065"},{"key":"3/4","hex":"#384865"},{"key":"3/6","hex":"#2d4872"},{"key":"3/8","hex":"#1c487e"},{"key":"3/12","hex":"#004798"},{"key":"4/6","hex":"#496089"},{"key":"4/10","hex":"#2961a3"},{"key":"4/4","hex":"#53607b"},{"key":"5/10","hex":"#487bbd"},{"key":"5/4","hex":"#6c7a94"},{"key":"5/8","hex":"#577ab0"},{"key":"6/4","hex":"#8694ad"},{"key":"6/6","hex":"#7c94bc"},{"key":"6/8","hex":"#7295ca"},{"key":"6/12","hex":"#5095e8"},{"key":"7/8","hex":"#8aafe6"},{"key":"7/10","hex":"#7bb0f7"},{"key":"7/12","hex":"#65b0ff"},{"key":"8/4","hex":"#b9c9e2"},{"key":"8/6","hex":"#adcaf4"},{"key":"8/12","hex":"#80cbff"},{"key":"9/2","hex":"#dde3ed"},{"key":"9/12","hex":"#96e7ff"},{"key":"1/100","hex":"#7295ca"},{"key":"2/100","hex":"#8aafe6"},{"key":"3/100","hex":"#ffffff"},{"key":"4/100","hex":"#E5ECF3"},{"key