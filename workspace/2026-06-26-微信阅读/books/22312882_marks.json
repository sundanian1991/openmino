{"synckey":1668617179,"updated":[{"bookId":"22312882","bookmarkId":"22312882_17_7310-7507","chapterUid":17,"markText":"总之，通过这个例子，我形成了以下心得：1.如果你能敏锐地捕捉行业分析师发掘的行情，那么你可以选择参与短线的、阶段性的行情。当然，这难度不小。2.如果你发现很多策略/宏观分析师吸纳了（多角度加持和印证了）行业分析师的观点，那么，很有可能，这波行情的级别比单单行业分析师的推荐要大。","range":"7488-7685","createTime":1563597884,"type":1},{"bookId":"22312882","bookmarkId":"22312882_10_4540-4597","chapterUid":10,"markText":"广发严佳炜的统计也显示，2007—2014年，中国股市有25%的股票没有分析师覆盖，25%的股票覆盖人数少于3人。","range":"4637-4694","createTime":1563577245,"type":1}],"removed":[],"chapters":[{"title":"6.策略研报与行业研报的互动（印证篇）","chapterUid":17,"chapterIdx":17},{"title":"3.看研报的捷径","chapterUid":10,"chapterIdx":10}],"book":{"bookId":"22312882","version":118548062,"format":"epub","soldout":1,"bookStatus":1,"cover":"https://cdn.weread.qq.com/weread/cover/26/YueWen_22312882/s_YueWen_22312882.jpg","title":"手把手教你读研报（雪球「岛」系列 ISLAND:18）","author":"齐齐鲁","coverBoxInfo":{"blurhash":"KEJ++a01X902IAs+ES%1NH","colors":[{"key":"1/4","hex":"#031d35"},{"key":"1/6","hex":"#001e41"},{"key":"1/8","hex":"#001e4d"},{"key":"2/4","hex":"#1b324b"},{"key":"2/6","hex":"#003358"},{"key":"2/8","hex":"#003365"},{"key":"3/4","hex":"#314964"},{"key":"3/6","hex":"#1d4a71"},{"key":"3/8","hex":"#004b7e"},{"key":"3/12","hex":"#004c98"},{"key":"4/6","hex":"#3d6388"},{"key":"4/10","hex":"#0064a3"},{"key":"4/4","hex":"#4b627b"},{"key":"5/10","hex":"#297ebd"},{"key":"5/4","hex":"#657c94"},{"key":"5/8","hex":"#457eaf"},{"key":"6/4","hex":"#8096ac"},{"key":"6/6","hex":"#7297bb"},{"key":"6/8","hex":"#6298ca"},{"key":"6/12","hex":"#1b9ae8"},{"key":"7/8","hex":"#7bb3e5"},{"key":"7/10","hex":"#63b4f5"},{"key":"7/12","hex":"#3eb5ff"},{"key":"8/4","hex":"#b2cbe2"},{"key":"8/6","hex":"#a2ccf3"},{"key":"8/12","hex":"#54d0ff"},{"key":"9/2","hex":"#dbe4ed"},{"key":"9/12","hex":"#6bedff"},{"key":"1/100","hex":"#6298ca"},{"key":"2/100","hex":"#7bb3e5"},{"key":"3/100","hex":"#ffffff"},{"key":"4/100","hex":"#E5ECF3"},{"key":"5/100","hex":"#E5ECF3"},{"key":"6/100","hex":"#001927"}],"domin