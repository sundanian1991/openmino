{"synckey":1590502718,"updated":[{"bookId":"30987780","bookmarkId":"30987780_4_3222-3379","chapterUid":4,"markText":"而卡尔维诺在《为什么读经典》中有更进一步的诠释。他认为，我们年轻时所读的东西，往往价值不大，这是因为我们没有耐心、精神不能集中、缺乏阅读技能，或因为我们缺乏人生经验。但是，它们将在我们的身体里起作用，当我们在成熟时期重读这些书，就会重新发现那些现已构成我们内在机制的一部分恒定事物，尽管我们已回忆不起它们从哪里来。","range":"3222-3379","createTime":1590502718,"type":1}],"removed":[],"chapters":[{"title":"序 只有在阅读中，思想才能统治黑暗","chapterUid":4,"chapterIdx":4}],"book":{"bookId":"30987780","version":748001273,"format":"epub","soldout":0,"bookStatus":1,"cover":"https://cdn.weread.qq.com/weread/cover/68/YueWen_30987780/s_YueWen_30987780.jpg","title":"影响商业的50本书","author":"吴晓波","coverBoxInfo":{"blurhash":"KJQcVM%gx|ncoftV$_WAWu","colors":[{"key":"1/4","hex":"#221b1b"},{"key":"1/6","hex":"#221b1b"},{"key":"1/8","hex":"#221b1b"},{"key":"2/4","hex":"#362f2e"},{"key":"2/6","hex":"#362f2e"},{"key":"2/8","hex":"#362f2e"},{"key":"3/4","hex":"#4d4644"},{"key":"3/6","hex":"#4d4644"},{"key":"3/8","hex":"#4d4644"},{"key":"3/12","hex":"#4d4644"},{"key":"4/6","hex":"#665e5d"},{"key":"4/10","hex":"#665e5d"},{"key":"4/4","hex":"#665e5d"},{"key":"5/10","hex":"#7f7876"},{"key":"5/4","hex":"#7f7876"},{"key":"5/8","hex":"#7f7876"},{"key":"6/4","hex":"#999290"},{"key":"6/6","hex":"#999290"},{"key":"6/8","hex":"#999290"},{"key":"6/12","hex":"#999290"},{"key":"7/8","hex":"#b3acaa"},{"key":"7/10","hex":"#b3acaa"},{"key":"7/12","hex":"#b3acaa"},{"key":"8/4","hex":"#ccc7c5"},{"key":"8/6","hex":"#ccc7c5"},{"key":"8/12","hex":"#ccc7c5"},{"key":"9/2","hex":"#e8e2e0"},{"key":"9/12","hex":"#e8e2e0"},{"key":"1/100","hex":"#999290"},{"key":"2/100","hex":"#b3acaa"},{"key":"3/100","hex":"#ffffff"},{"key":"4/100","hex":"#F3E8E5"},{"key":"5/100","hex":"#F3E8E5"},{"key":"6/100","hex":"#270500"}],"dominate_color":{"hex":"#e9e3e1","hsv":[17.2122715051821,3.142054068786945,91.2521620132986]},"custom_cover":"https://weread-1258476243.file.myqcloud.com/bookalphacover/780/30987780/s_30987780.jpg","custom_rec_cover":"https://weread-1258476243.file.myqcloud.com/b