{"synckey":1682099752,"updated":[{"bookId":"24129813","bookmarkId":"24129813_5_1109-1297","chapterUid":15,"markText":"这桩丝绢案在《明实录》里却只有一句冷冰冰的记录，但如果把《丝绢全书》里的细节加入其中，整个事件就立刻变得鲜活起来。里面的钩心斗角，里面的人心百态，当时官场和民间的各种潜规则，简直比电视剧还精彩。我们看到的，是一个个有血有肉的人，是一篇篇生动细腻的故事。这种史学意义上的“起死人，肉白骨”，已具备了文学上的美感。","range":"910-1096","createTime":1651614149,"type":1}],"removed":[],"chapters":[{"title":"序言","chapterUid":15,"chapterIdx":5}],"book":{"bookId":"24129813","version":48576004,"format":"epub","soldout":0,"bookStatus":1,"cover":"https://wfqqreader-1252317822.image.myqcloud.com/cover/813/24129813/s_24129813.jpg","title":"显微镜下的大明","author":"马伯庸","coverBoxInfo":{"blurhash":"KxNKL:xvae0KV@of4-RjWB","colors":[{"key":"1/4","hex":"#002310"},{"key":"1/6","hex":"#002607"},{"key":"1/8","hex":"#002801"},{"key":"2/4","hex":"#173724"},{"key":"2/6","hex":"#003a1c"},{"key":"2/8","hex":"#003c15"},{"key":"3/4","hex":"#2b4f37"},{"key":"3/6","hex":"#12522e"},{"key":"3/8","hex":"#005526"},{"key":"3/12","hex":"#005a13"},{"key":"4/6","hex":"#2c6d42"},{"key":"4/10","hex":"#00732d"},{"key":"4/4","hex":"#42694c"},{"key":"5/10","hex":"#008d44"},{"key":"5/4","hex":"#5c8364"},{"key":"5/8","hex":"#2f8a4e"},{"key":"6/4","hex":"#749d7c"},{"key":"6/6","hex":"#63a170"},{"key":"6/8","hex":"#4da565"},{"key":"6/12","hex":"#00ac4e"},{"key":"7/8","hex":"#6ac07d"},{"key":"7/10","hex":"#51c470"},{"key":"7/12","hex":"#28c764"},{"key":"8/4","hex":"#a7d3ac"},{"key":"8/6","hex":"#95d89f"},{"key":"8/12","hex":"#4ee37a"},{"key":"9/2","hex":"#d0ead2"},{"key":"9/12","hex":"#67ff8e"},{"key":"1/100","hex":"#4da565"},{"key":"2/100","hex":"#6ac07d"},{"key":"3/100","hex":"#ffffff"},{"key":"4/100","hex":"#E5F3E9"},{"key":"5/100","hex":"#E5F3E9"},{"key":"6/100","hex":"#002706"}],"dominate_color":{"hex":"#16522f","hsv":[144.85534027905369,72.89691924802092,32.051111517316048]},"custom_cover":"https://weread-1258476243.file.myqcloud.com/bookalphacover/813/24129813/s_24129813.jpg","custom_rec_cover":"https://weread-1258476243.file.myqcloud.com/bookreccover/