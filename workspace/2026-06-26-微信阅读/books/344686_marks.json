{"synckey":1587994531,"updated":[{"bookId":"344686","bookmarkId":"344686_4_3327-3424","chapterUid":4,"markText":"生产铅笔的木材、铅和黏土都是直接参与了生产的成本，这叫作营业成本，但给销售人员的工资就不是营业成本。因为销售人员只负责卖铅笔，并不生产铅笔，这就是差别。参与了生产，就是营业成本，没参与，就不是。","range":"3327-3424","createTime":1587994531,"type":1}],"removed":[],"chapters":[{"title":"第1章 为什么要看财报","chapterUid":4,"chapterIdx":4}],"book":{"bookId":"344686","version":1537219736,"format":"epub","soldout":0,"bookStatus":1,"cover":"https://cdn.weread.qq.com/weread/cover/89/YueWen_344686/s_YueWen_344686.jpg","title":"人人都看得懂的财报书","author":"孟庆宇","coverBoxInfo":{"blurhash":"KPQl^6rq~W?GX8D*yDcENa","colors":[{"key":"1/4","hex":"#001f34"},{"key":"1/6","hex":"#002040"},{"key":"1/8","hex":"#00214c"},{"key":"2/4","hex":"#12344a"},{"key":"2/6","hex":"#003556"},{"key":"2/8","hex":"#003664"},{"key":"3/4","hex":"#284b63"},{"key":"3/6","hex":"#014c70"},{"key":"3/8","hex":"#004e7c"},{"key":"3/12","hex":"#005096"},{"key":"4/6","hex":"#2f6587"},{"key":"4/10","hex":"#0068a1"},{"key":"4/4","hex":"#44647a"},{"key":"5/10","hex":"#0082bb"},{"key":"5/4","hex":"#5f7d93"},{"key":"5/8","hex":"#2e81ae"},{"key":"6/4","hex":"#7997ac"},{"key":"6/6","hex":"#6699ba"},{"key":"6/8","hex":"#4e9bc8"},{"key":"6/12","hex":"#009fe5"},{"key":"7/8","hex":"#69b6e3"},{"key":"7/10","hex":"#43b8f3"},{"key":"7/12","hex":"#00baff"},{"key":"8/4","hex":"#accce2"},{"key":"8/6","hex":"#97cff1"},{"key":"8/12","hex":"#00d6ff"},{"key":"9/2","hex":"#d7e5ed"},{"key":"9/12","hex":"#1df3ff"},{"key":"1/100","hex":"#4e9bc8"},{"key":"2/100","hex":"#69b6e3"},{"key":"3/100","hex":"#ffffff"},{"key":"4/100","hex":"#E5ECF3"},{"key":"5/100","hex":"#E5ECF3"},{"key":"6/100","hex":"#001927"}],"dominate_color":{"hex":"#2f5169","hsv":[205.2536575009493,55.72342812923197,41.3509769781389]},"custom_cover":"https://weread-1258476243.file.myqcloud.com/bookalphacover/686/344686/s_344686.jpg","custom_rec_cover":"https://weread-1258476243.file.myqcloud.com/bookreccover/686/344686/s_344686.jpg","colorsPure":["#009fe5","#00baff"]}}}