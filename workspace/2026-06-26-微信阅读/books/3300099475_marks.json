{"synckey":1717113605,"updated":[{"bookId":"3300099475","bookmarkId":"3300099475_8_20669-20703","createTime":1717113605,"chapterUid":8,"colorStyle":3,"type":1,"markText":"在信息化的过程中，脑力劳动被从每个人的大脑中转移出来，形成了信息产业","range":"20669-20703"},{"bookId":"3300099475","bookmarkId":"3300099475_8_20631-20665","createTime":1717113598,"chapterUid":8,"colorStyle":3,"type":1,"markText":"在城市化的进程中，更多的手工劳动被从家庭中转移出来，形成了制造产业；","range":"20631-20665"},{"bookId":"3300099475","bookmarkId":"3300099475_8_20590-20628","createTime":1717113594,"chapterUid":8,"colorStyle":3,"type":1,"markText":"在劳动分工出现后，一些体力劳动被慢慢地从家庭中转移出来，形成了新的农牧产业；","range":"20590-20628"},{"bookId":"3300099475","bookmarkId":"3300099475_8_20524-20561","createTime":1717113586,"chapterUid":8,"colorStyle":3,"type":1,"markText":"所有的行业都起源于家庭，在劳动分工出现之前，所有人都只消费自己的劳动成果。","range":"20524-20561"},{"bookId":"3300099475","bookmarkId":"3300099475_8_20265-20340","createTime":1717113570,"chapterUid":8,"colorStyle":3,"type":1,"markText":"在谈行业的终局之前，我们先来看行业的起源和分类。任何一个行业都不是天然存在的，随着时间的推移和环境的改变，一些新的行业会出现，一些旧的行业会慢慢消亡。","range":"20265-20340"},{"bookId":"3300099475","bookmarkId":"3300099475_7_5305-5406","createTime":1716590091,"chapterUid":7,"colorStyle":3,"type":1,"markText":"人口出生率是婴儿用品市场的前置指标，人口老龄化是老年用品市场的前置指标，结婚率是大家电市场的前置指标，可支配收入是市场需求的前置指标等。大部分事件在发生之前都有明确的前置指标，找到这些前置指标并不困难。","range":"5305-5406"},{"bookId":"3300099475","bookmarkId":"3300099475_7_4798-4836","createTime":1716590068,"chapterUid":7,"colorStyle":3,"type":1,"markText":"前置指标可用于替代不断试错及实际观察，是发生在重要事件之前的一些现象和变化。","range":"4798-4836"},{"bookId":"3300099475","bookmarkId":"3300099475_7_4609-4674","createTime":1716590045,"chapterUid":7,"colorStyle":3,"type":1,"markText":"在盛夏炎热的午后，当天空中乌云密布、电闪雷鸣、狂风大作时，我们就知道马上要下雨了。乌云、闪电、雷声和狂风就是下雨这件事的前置指标。","range":"4609-4674"},{"bookId":"3300099475","bookmarkId":"3300099475_7_4419-4525","createTime":1716590034,"chapterUid":7,"colorStyle":3,"type":1,"markText":"通过对前置指标的学习、量化和分析，发现不同指标间相互影响的顺序和规律就可以获得远见。其中最重要、最有效的方法是类比分析。历史总会高度相似，但又不是简单地重复。过去的教训为未来的行为提供指导，在商业行为中也是如此。","range":"4419-4525"},{"bookId":"3300099475","bookmarkId":"3300099475_7_4372-4390","createTime":1716590026,"chapterUid":7,"colorStyle":3,"type":1,"markText":"解决商业问题最有效的方法是类比分析。","range":"4372-4390"},{"bookId":"3300099475","bookmarkId":"3300099475_7_4237-4285","createTime":1716590019,"chapterUid":7,"colorStyle":3,"type":1,"markText":"无论是误打误撞、跟随趋势，还是洞察数据，都是远见的预兆。我们将这些预兆称为远见的信使：前置指标。","range":"4237-4285"}],"removed":[],"chapters":[{"title":"第1章 持续增长的秘密","chapterUid":7,"chapterIdx":7},{"title":"第2章 商业环境演进的底层逻辑","chapterUid":8,"chapterIdx":8}],"book":{"bookId":"3300099475","version":1696545387,"format":"epub","soldout":0,"bookStatus":1,"cover":"https://cdn.weread.qq.com/weread/cover/62/cpplatform_nqfj4tcurhsmxsibddtoof/s_cpplatform_nqfj4tcurhsmxsibddtoof1715414888.jpg","title":"商业分析：洞察真实商业世界的逻辑与策略","author":"王彦平","coverBoxInfo":{"blurhash":"K7AwC%Vr00Ipxvi^xYr=-q","colors":[{"key":"1/4","hex":"#1d1c1c"},{"key":"1/6","hex":"#1d1c1c"},{"key":"1/8","hex":"#1d1c1c"},{"key":"2/4","hex":"#323130"},{"key":"2/6","hex":"#323130"},{"key":"2/8","hex":"#323130"},{"key":"3/4","hex":"#494747"},{"key":"3/6","hex":"#494747"},{"key":"3/8","hex":"#494747"},{"key":"3/12","hex":"#494747"},{"key":"4/6","hex":"#61605f"},{"key":"4/10","hex":"#61605f"},{"key":"4/4","hex":"#61605f"},{"key":"5/10","hex":"#7b7978"},{"key":"5/4","hex":"#7b7978"},{"key":"5/8","hex":"#7b7978"},{"key":"6/4","hex":"#959392"},{"key":"6/6","hex":"#959392"},{"key":"6/8","hex":"#959392"},{"key":"6/12","hex":"#959392"},{"key":"7/8","hex":"#afadac"},{"key":"7/10","hex":"#afadac"},{"key":"7/12","hex":"#afadac"},{"key":"8/4","hex":"#c9c8c7"},{"key":"8/6","hex":"#c9c8c7"},{"key":"8/12","hex":"#c9c8c7"},{"key":"9/2","hex":"#e4e3e2"},{"key":"9/12","hex":"#e4e3e2"},{"key":"1/100","hex":"#959392"},{"key":"2/100","hex":"#afadac"},{"key":"3/100","hex":"#ffffff"},{"key":"4/100","hex":"#EEEEEE"},{"key":"5/100","hex":"#EEEEEE"},{"key":"6/100","hex":"#000000"}],"dominate_color":{"hex":"#050202","hsv":[1.0156085626845973,62.08866215034128,2.1115332