{"synckey":1596664598,"updated":[{"bookId":"23566790","bookmarkId":"23566790_19_5736-5908","chapterUid":19,"markText":"快乐对人的神经系统有着很微妙的影响，通过它神经系统能够得到强化和改善。我们的勇气、决心、抱负都因为童年的快乐增强了，我们对人生的看法也随之改变了。快乐就好像是来自幽默和娱乐的一股微妙的液体，它在我们的身体里流淌，清洗所有的神经器官，清除大脑中的垃圾和残骸（这些垃圾和残骸令我们的大脑精疲力竭）。我们都感受过焕然一新的感觉，感受过有益身心的快乐。","range":"5736-5908","createTime":1596664598,"type":1}],"removed":[],"chapters":[{"title":"第十六章 快乐——上帝的灵丹妙药","chapterUid":19,"chapterIdx":19}],"book":{"bookId":"23566790","version":194816769,"format":"epub","soldout":0,"bookStatus":1,"cover":"https://cdn.weread.qq.com/weread/cover/26/YueWen_23566790/s_YueWen_23566790.jpg","title":"好好思考：如何通过转换思维达到人生理想状态","author":"奥里森·马登","coverBoxInfo":{"blurhash":"KDSidFM}?wIURjoz9JM_%0","colors":[{"key":"1/4","hex":"#241c00"},{"key":"1/6","hex":"#271c00"},{"key":"1/8","hex":"#2a1c00"},{"key":"2/4","hex":"#383103"},{"key":"2/6","hex":"#3a3100"},{"key":"2/8","hex":"#3c3100"},{"key":"3/4","hex":"#4f481d"},{"key":"3/6","hex":"#514800"},{"key":"3/8","hex":"#534800"},{"key":"3/12","hex":"#544900"},{"key":"4/6","hex":"#6b6112"},{"key":"4/10","hex":"#6e6100"},{"key":"4/4","hex":"#69612f"},{"key":"5/10","hex":"#897b00"},{"key":"5/4","hex":"#827b47"},{"key":"5/8","hex":"#887b00"},{"key":"6/4","hex":"#9c9560"},{"key":"6/6","hex":"#a09543"},{"key":"6/8","hex":"#a2951f"},{"key":"6/12","hex":"#a59500"},{"key":"7/8","hex":"#bdb03e"},{"key":"7/10","hex":"#bfb003"},{"key":"7/12","hex":"#c1b000"},{"key":"8/4","hex":"#d1ca90"},{"key":"8/6","hex":"#d5ca74"},{"key":"8/12","hex":"#dccb00"},{"key":"9/2","hex":"#e8e4c2"},{"key":"9/12","hex":"#f8e713"},{"key":"1/100","hex":"#a2951f"},{"key":"2/100","hex":"#bdb03e"},{"key":"3/100","hex":"#ffffff"},{"key":"4/100","hex":"#F3F1E5"},{"key":"5/100","hex":"#F3F1E5"},{"key":"6/100","hex":"#271E00"}],"dominate_color":{"hex":"#f9ee8b","hsv":[54.13752493277696,44.076657309436409,97.6059886273663]},"custom_cover":"https://weread-1258476243.file.myqcloud.com/bookalphacover/790/23566790/s_23566790.jpg","custom_rec_cover":"https://we