{"synckey":1591411946,"updated":[{"bookId":"27600227","bookmarkId":"27600227_7_4770-5049","createTime":1591411946,"range":"4770-5049","markText":"低碳水化合物饮食的创立者是简·安瑟米·布理勒特-萨瓦林（1755—1826）。他在1825年写过一本颇有影响力的教科书《味觉的生理基础》。他在书中写道：“肥胖的第二个主要原因是摄入面粉和淀粉类物质，它们是人类日常营养的主要来源。正如我们曾经提到的，不管你是否愿意，以淀粉类物质为主要食物的所有动物都长脂肪。这是一条普遍规律，人类也不例外。”4\n","type":1,"chapterUid":7}],"removed":[],"chapters":[{"title":"第1部分 肥胖症的流行","chapterUid":7,"chapterIdx":7}],"book":{"bookId":"27600227","version":338690578,"format":"epub","soldout":1,"bookStatus":1,"cover":"https://cdn.weread.qq.com/weread/cover/26/YueWen_27600227/s_YueWen_27600227.jpg","title":"肥胖代码：减肥的秘密","author":"冯子新","coverBoxInfo":{"blurhash":"KHErzPjtEv-qNLIU0yjZ-D","colors":[{"key":"1/4","hex":"#002320"},{"key":"1/6","hex":"#002623"},{"key":"1/8","hex":"#002926"},{"key":"2/4","hex":"#023834"},{"key":"2/6","hex":"#003a35"},{"key":"2/8","hex":"#003d37"},{"key":"3/4","hex":"#15504a"},{"key":"3/6","hex":"#00534b"},{"key":"3/8","hex":"#00564d"},{"key":"3/12","hex":"#005b51"},{"key":"4/6","hex":"#006d63"},{"key":"4/10","hex":"#007467"},{"key":"4/4","hex":"#306a62"},{"key":"5/10","hex":"#008f7d"},{"key":"5/4","hex":"#4c847a"},{"key":"5/8","hex":"#008c7c"},{"key":"6/4","hex":"#639e93"},{"key":"6/6","hex":"#44a393"},{"key":"6/8","hex":"#00a794"},{"key":"6/12","hex":"#00ae97"},{"key":"7/8","hex":"#34c2ac"},{"key":"7/10","hex":"#00c6ad"},{"key":"7/12","hex":"#00c9ae"},{"key":"8/4","hex":"#97d4c6"},{"key":"8/6","hex":"#7ad9c5"},{"key":"8/12","hex":"#00e6c6"},{"key":"9/2","hex":"#c8eae1"},{"key":"9/12","hex":"#00ffe0"},{"key":"1/100","hex":"#00a794"},{"key":"2/100","hex":"#34c2ac"},{"key":"3/100","hex":"#ffffff"},{"key":"4/100","hex":"#E5F3EF"},{"key":"5/100","hex":"#E5F3EF"},{"key":"6/100","hex":"#002714"}],"dominate_color":{"hex":"#5bc4b1","hsv":[168.84635904185738,53.59712040653084,76.94707100174094]},"custom_cover":"https://weread-1258476243.file.myqcloud.com/bookalphacover/227/27600227/s_27600227.jpg","custom_rec_cover":"https://weread-1258476243.file.