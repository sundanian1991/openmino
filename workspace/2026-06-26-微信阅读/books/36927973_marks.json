{"synckey":1616249154,"updated":[{"bookId":"36927973","bookmarkId":"36927973_3_1408-1569","chapterUid":3,"markText":"历史学家不仅要把“此刻”记录下来，还要在历史中找到那些构成记忆节点的“此刻”，为它们赋予统一连贯的意义，让它们构成我们的“历史”，构成“我们”；在灾难之时，为这个民族埋下他日能够精神涅槃的种子。对历史学家来说，每一个被经历的时刻都是“此刻”，转瞬即逝的“此刻”却又在记忆中绵延不绝。历史学家如何记忆，这个民族就会如何记忆。","range":"1408-1569","createTime":1616249154,"type":1}],"removed":[],"chapters":[{"title":"前言 记忆与未来","chapterUid":3,"chapterIdx":3}],"book":{"bookId":"36927973","version":212526308,"format":"epub","soldout":0,"bookStatus":1,"cover":"https://wfqqreader-1252317822.image.myqcloud.com/cover/973/36927973/s_36927973.jpg","title":"破茧","author":"施展","coverBoxInfo":{"blurhash":"KlN0^+ayxu~payt69FfQRj","colors":[{"key":"1/4","hex":"#291a00"},{"key":"1/6","hex":"#2d1900"},{"key":"1/8","hex":"#321800"},{"key":"2/4","hex":"#3d2f04"},{"key":"2/6","hex":"#412f00"},{"key":"2/8","hex":"#442e00"},{"key":"3/4","hex":"#54461d"},{"key":"3/6","hex":"#584600"},{"key":"3/8","hex":"#5b4500"},{"key":"3/12","hex":"#604400"},{"key":"4/6","hex":"#725e15"},{"key":"4/10","hex":"#775e00"},{"key":"4/4","hex":"#6e5f30"},{"key":"5/10","hex":"#947700"},{"key":"5/4","hex":"#887948"},{"key":"5/8","hex":"#917701"},{"key":"6/4","hex":"#a29360"},{"key":"6/6","hex":"#a89245"},{"key":"6/8","hex":"#ac9224"},{"key":"6/12","hex":"#b19100"},{"key":"7/8","hex":"#c7ac41"},{"key":"7/10","hex":"#cbac12"},{"key":"7/12","hex":"#ceab00"},{"key":"8/4","hex":"#d6c891"},{"key":"8/6","hex":"#dcc876"},{"key":"8/12","hex":"#e9c600"},{"key":"9/2","hex":"#ebe3c3"},{"key":"9/12","hex":"#ffe221"},{"key":"1/100","hex":"#ac9224"},{"key":"2/100","hex":"#c7ac41"},{"key":"3/100","hex":"#ffffff"},{"key":"4/100","hex":"#F3F1E5"},{"key":"5/100","hex":"#F3F1E5"},{"key":"6/100","hex":"#271E00"}],"dominate_color":{"hex":"#e4e0d2","hsv":[45.183674798195088,8.018158434806404,89.48221097277329]},"custom_cover":"https://weread-1258476243.file.myqcloud.com/bookalphacover/973/36927973/s_36927973.jpg","custom_rec_cover":"https://weread-1258476243.file.myqcloud.com/bookrecc