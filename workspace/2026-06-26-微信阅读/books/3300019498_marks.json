{"synckey":1706706646,"updated":[{"bookId":"3300019498","bookmarkId":"3300019498_11_42358-42359","createTime":1706706616,"chapterUid":11,"colorStyle":3,"type":1,"markText":"[插图]","range":"42358-42359"},{"bookId":"3300019498","bookmarkId":"3300019498_11_7247-7302","createTime":1706702057,"chapterUid":11,"colorStyle":3,"type":1,"markText":"要通过数据分析来驱动业务发展，最直接也最有效的方式莫过于找到当前的业务痛点并针对性地解决，也就是“一击立威”。","range":"7247-7302"},{"bookId":"3300019498","bookmarkId":"3300019498_11_4734-4753","createTime":1706701512,"chapterUid":11,"colorStyle":3,"type":1,"markText":"对于发现的问题，要能够清晰地定义出来。","range":"4734-4753"},{"bookId":"3300019498","bookmarkId":"3300019498_11_4406-4449","createTime":1706701483,"chapterUid":11,"colorStyle":3,"type":1,"markText":"关键业务节点有两个特征：一是能够推进业务往下进行；二是能够推动业务在不同角色之间流转。","range":"4406-4449"},{"bookId":"3300019498","bookmarkId":"3300019498_11_4234-4282","createTime":1706701466,"chapterUid":11,"colorStyle":3,"type":1,"markText":"我们可以把解决问题的框架整理为：发现问题→定义问题→寻找原因→提出解决方案→落地执行→反馈迭代。","range":"4234-4282"},{"bookId":"3300019498","bookmarkId":"3300019498_11_1090-1154","createTime":1706701120,"chapterUid":11,"colorStyle":3,"type":1,"markText":"数据化运营流程分为五个步骤，即业务问题的定义与拆解、数据获取与网络爬虫、数据探索与预处理、数据分析与挖掘、数据可视化与数据决策。","range":"1090-1154"},{"bookId":"3300019498","bookmarkId":"3300019498_9_20671-20700","createTime":1706701022,"chapterUid":9,"colorStyle":3,"type":1,"markText":"创造价值，要求企业管理者做到三懂，懂收入、懂支出、懂风险。","range":"20671-20700"}],"removed":[],"chapters":[{"title":"第3章 数据化运营的业务流程","chapterUid":11,"chapterIdx":11},{"title":"第2章 企业中的数据化运营","chapterUid":9,"chapterIdx":9}],"book":{"bookId":"3300019498","version":1047174472,"format":"epub","soldout":0,"bookStatus":1,"cover":"https://cdn.weread.qq.com/weread/cover/98/3300019498/s_3300019498.jpg","title":"商业智能数据化运营实战","author":"王鑫","coverBoxInfo":{"blurhash":"KDOl=ToeHZyVj?VZHZaft+","colors":[{"key":"1/4","hex":"#370e13"},{"key":"1/6","hex":"#400210"},{"key":"1/8","hex":"#48000e"},{"key":"2/4","hex":"#4d2522"},{"key":"2/6","hex":"#571e1b"},{"key":"