{"synckey":1596264102,"updated":[{"bookId":"920427","bookmarkId":"920427_3_715-870","chapterUid":3,"markText":"首先，你将评估自己属于什么类型、具备何种特殊品质，从而帮助你开发自我意识、明确个人目标。然后你将认识到，对于令人满意的生活来说，自尊和积极思考的重要性。同时你也会认识到在向自我目标不懈前进的道路上必需的工具：自我约束和自我激励。一旦你掌握了这些心理学工具，你将学会时间和金钱管理、沟通和积极人际关系的基本法则。","range":"715-870","createTime":1596264102,"type":1}],"removed":[],"chapters":[{"title":"前言","chapterUid":3,"chapterIdx":3}],"book":{"bookId":"920427","version":1503109497,"format":"epub","soldout":0,"bookStatus":1,"cover":"https://wfqqreader-1252317822.image.myqcloud.com/cover/427/920427/s_920427.jpg","title":"成功心理学：发现工作与生活的意义","author":"丹尼斯·韦特利","coverBoxInfo":{"blurhash":"K7RypY~q?v~p%Mt7V?D%M{","colors":[{"key":"1/4","hex":"#201b1a"},{"key":"1/6","hex":"#201b1a"},{"key":"1/8","hex":"#201b1a"},{"key":"2/4","hex":"#35302f"},{"key":"2/6","hex":"#35302f"},{"key":"2/8","hex":"#35302f"},{"key":"3/4","hex":"#4c4645"},{"key":"3/6","hex":"#4c4645"},{"key":"3/8","hex":"#4c4645"},{"key":"3/12","hex":"#4c4645"},{"key":"4/6","hex":"#655f5d"},{"key":"4/10","hex":"#655f5d"},{"key":"4/4","hex":"#655f5d"},{"key":"5/10","hex":"#7e7877"},{"key":"5/4","hex":"#7e7877"},{"key":"5/8","hex":"#7e7877"},{"key":"6/4","hex":"#989290"},{"key":"6/6","hex":"#989290"},{"key":"6/8","hex":"#989290"},{"key":"6/12","hex":"#989290"},{"key":"7/8","hex":"#b2acaa"},{"key":"7/10","hex":"#b2acaa"},{"key":"7/12","hex":"#b2acaa"},{"key":"8/4","hex":"#ccc7c5"},{"key":"8/6","hex":"#ccc7c5"},{"key":"8/12","hex":"#ccc7c5"},{"key":"9/2","hex":"#e7e2e0"},{"key":"9/12","hex":"#e7e2e0"},{"key":"1/100","hex":"#989290"},{"key":"2/100","hex":"#b2acaa"},{"key":"3/100","hex":"#ffffff"},{"key":"4/100","hex":"#EEEEEE"},{"key":"5/100","hex":"#EEEEEE"},{"key":"6/100","hex":"#000000"}],"dominate_color":{"hex":"#b7b2b0","hsv":[14.406951889422937,3.3232905820748277,71.58989147757457]},"custom_cover":"https://weread-1258476243.file.myqcloud.com/bookalphacover/427/920427/s_920427.jpg","custom_rec_cover":"https://weread-1258476243.file.myqcloud.com/bookreccover/427/