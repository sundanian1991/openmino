{"synckey":1707866951,"updated":[{"bookId":"3300025801","bookmarkId":"3300025801_7_33587-33816","createTime":1707866924,"chapterUid":7,"colorStyle":3,"type":1,"markText":"开始临摹的帖，仔细地从一点一画多看几遍，然后再对着它下笔临写，起初只要注意每一笔一画的起讫，每笔都有其体会，都有了几分相像了，就可注意到它们的配搭。开始时期中，必然感到有些困难，不会容易得到帖的好处，但是，经过了一个相当长的“心摹手追”的手脑并用时期，便能渐渐地和帖相接近了，再过了几时，便会把前代书家的笔势笔意和自己的脑和手的动作不知不觉地融合起来，即使离开了帖，独立写字，也会有几分类似处，因为已经能够活用它的笔势和笔意了，必须做到这样，才算是有些成绩。","range":"33587-33816"}],"removed":[],"chapters":[{"title":"辑一 学书","chapterUid":7,"chapterIdx":6}],"book":{"bookId":"3300025801","version":952935877,"format":"epub","soldout":0,"bookStatus":1,"cover":"https://cdn.weread.qq.com/weread/cover/9/cpPlatform_3300025801/s_cpPlatform_3300025801.jpg","title":"秋明随笔","author":"沈尹默","coverBoxInfo":{"blurhash":"K-J*SHayIo00WBRj-=WCof","colors":[{"key":"1/4","hex":"#371003"},{"key":"1/6","hex":"#3e0700"},{"key":"1/8","hex":"#440000"},{"key":"2/4","hex":"#4b2818"},{"key":"2/6","hex":"#532208"},{"key":"2/8","hex":"#5c1b00"},{"key":"3/4","hex":"#643e2b"},{"key":"3/6","hex":"#6e3a1b"},{"key":"3/8","hex":"#753503"},{"key":"3/12","hex":"#812c00"},{"key":"4/6","hex":"#895331"},{"key":"4/10","hex":"#994a00"},{"key":"4/4","hex":"#7f5740"},{"key":"5/10","hex":"#b8631f"},{"key":"5/4","hex":"#99715a"},{"key":"5/8","hex":"#b06835"},{"key":"6/4","hex":"#b38b72"},{"key":"6/6","hex":"#c18660"},{"key":"6/8","hex":"#cc824e"},{"key":"6/12","hex":"#dd791e"},{"key":"7/8","hex":"#e89c67"},{"key":"7/10","hex":"#f29853"},{"key":"7/12","hex":"#fc933a"},{"key":"8/4","hex":"#eabfa4"},{"key":"8/6","hex":"#f8bb92"},{"key":"8/12","hex":"#ffad52"},{"key":"9/2","hex":"#f4dfd1"},{"key":"9/12","hex":"#ffc86c"},{"key":"1/100","hex":"#cc824e"},{"key":"2/100","hex":"#e89c67"},{"key":"3/100","hex":"#ffffff"},{"key":"4/100","hex":"#F3E8E5"},{"key":"5/100","hex":"#F3E8E5"},{"key":"6/100","hex":"#270500"}],"dominate_color":{"hex":"#b59b8c","hsv":[22.62861452064188,22.625011377082008,70.87369163556932]},"custom_cover":"https://weread-1258476243.file.myqcloud.com/bookalphacover/