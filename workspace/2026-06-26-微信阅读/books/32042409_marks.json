{"synckey":1668633036,"updated":[{"bookId":"32042409","bookmarkId":"32042409_11_3220-3455","chapterUid":11,"markText":"学习的本质：首先，我们遇到一个无法解决的新问题；然后，我们产生挫败感；接着，我们开始输入各种新知识；最后，我们会对新知识进行整合消化，输出一个新的解释系统。这4个环节缺一不可，尤其是最后一个输出过程，它是对这些信息加以处理，与你原有的知识体系、经验体验联结起来，完成深度学习的重要步骤。但是，很多人的学习行为往往就止步在前三个环节，忘记了对新知识进行输出。只有输入却没有输出，就像搬来了大量砖头，但只是杂乱地堆在一起——这些砖头若没有经过规则地堆砌，就无法成为房屋建筑。","range":"3220-3455","createTime":1594245637,"type":1}],"removed":[],"chapters":[{"title":"第二节 收藏正在成为一种伪学习","chapterUid":11,"chapterIdx":11}],"book":{"bookId":"32042409","version":251088951,"format":"epub","soldout":1,"bookStatus":1,"cover":"https://cdn.weread.qq.com/weread/cover/50/YueWen_32042409/s_YueWen_32042409.jpg","title":"五维学习力","author":"王咏","coverBoxInfo":{"blurhash":"KALf:XoJ~V^*oLksm*ozIV","colors":[{"key":"1/4","hex":"#351200"},{"key":"1/6","hex":"#3b0c00"},{"key":"1/8","hex":"#420300"},{"key":"2/4","hex":"#482914"},{"key":"2/6","hex":"#502500"},{"key":"2/8","hex":"#572100"},{"key":"3/4","hex":"#624028"},{"key":"3/6","hex":"#6a3c14"},{"key":"3/8","hex":"#703900"},{"key":"3/12","hex":"#7b3200"},{"key":"4/6","hex":"#86552b"},{"key":"4/10","hex":"#934f00"},{"key":"4/4","hex":"#7d583c"},{"key":"5/10","hex":"#b2680e"},{"key":"5/4","hex":"#977256"},{"key":"5/8","hex":"#ab6a2c"},{"key":"6/4","hex":"#b28c6f"},{"key":"6/6","hex":"#be885a"},{"key":"6/8","hex":"#c88545"},{"key":"6/12","hex":"#d67e00"},{"key":"7/8","hex":"#e39f5f"},{"key":"7/10","hex":"#ec9c47"},{"key":"7/12","hex":"#f49829"},{"key":"8/4","hex":"#e8c1a0"},{"key":"8/6","hex":"#f5bd8c"},{"key":"8/12","hex":"#ffb344"},{"key":"9/2","hex":"#f4e0ce"},{"key":"9/12","hex":"#ffcd5e"},{"key":"1/100","hex":"#c88545"},{"key":"2/100","hex":"#e39f5f"},{"key":"3/100","hex":"#ffffff"},{"key":"4/100","hex":"#F3EDE5"},{"key":"5/100","hex":"#F3EDE5"},{"key":"6/100","hex":"#271300"}],"dominate_color":{"hex":"#bd9575","hsv":[26.6065043782562,37.99456627423092,74.05926539138938]},"custom_cover":"https://weread-1258476243.file.myqcloud.com/bookalphacover/409/32042409/s_320