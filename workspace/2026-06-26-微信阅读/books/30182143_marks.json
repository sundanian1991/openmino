{"synckey":1674539467,"updated":[{"bookId":"30182143","bookmarkId":"30182143_6_1075-1105","createTime":1674539467,"chapterUid":6,"type":1,"markText":"常用的预处理方法有两种：靠水加热的叫焯水，靠油加热的叫滑油。","range":"1075-1105"},{"bookId":"30182143","bookmarkId":"30182143_6_746-1005","createTime":1674539457,"chapterUid":6,"type":1,"markText":"第一类，靠油来加热—炒、熘、炸。油的沸点高，食材熟得快、口感脆嫩。但因为烹饪时间短，这类技法要求事先把食材切成小块。第二类，靠水及水蒸气来加热—烧、炖、蒸。水的沸点不及油高，食材熟得慢，但相对来说更易入味，口感软嫩。第三类，不加热—凉拌。","range":"746-1005"},{"bookId":"30182143","bookmarkId":"30182143_6_518-664","createTime":1674539433,"chapterUid":6,"type":1,"markText":"烹饪技法理解为做菜的“套路”，它们是老祖宗在实践中不断总结出来的，让食材达到某种特定口味、口感的最有效的方法。食材虽多，但方法有限，据统计，中国菜有30多种烹饪技法，而家常用的不过7种。只要理解了这常用的7种技法，光看菜名而不看菜谱就能做出一道菜肴。掌握这些技法，可以说是做出好菜的一大捷径！","range":"518-664"}],"removed":[],"chapters":[{"title":"一、烹饪的技法","chapterUid":6,"chapterIdx":6}],"book":{"bookId":"30182143","version":952608856,"format":"epub","soldout":0,"bookStatus":1,"cover":"https://cdn.weread.qq.com/weread/cover/82/YueWen_30182143/s_YueWen_30182143.jpg","title":"做好一道菜","author":"罗生堂","coverBoxInfo":{"blurhash":"K~M%s6ofj[4Tj]WBt7WCof","colors":[{"key":"1/4","hex":"#370e15"},{"key":"1/6","hex":"#400213"},{"key":"1/8","hex":"#480011"},{"key":"2/4","hex":"#4d2524"},{"key":"2/6","hex":"#571d1e"},{"key":"2/8","hex":"#611118"},{"key":"3/4","hex":"#683b35"},{"key":"3/6","hex":"#74342c"},{"key":"3/8","hex":"#7f2b23"},{"key":"3/12","hex":"#93030e"},{"key":"4/6","hex":"#8f4e43"},{"key":"4/10","hex":"#a53e2e"},{"key":"4/4","hex":"#82544c"},{"key":"5/10","hex":"#c35943"},{"key":"5/4","hex":"#9c6f66"},{"key":"5/8","hex":"#b7614f"},{"key":"6/4","hex":"#b6897f"},{"key":"6/6","hex":"#c48374"},{"key":"6/8","hex":"#d27c69"},{"key":"6/12","hex":"#eb6d4f"},{"key":"7/8","hex":"#f09680"},{"key":"7/10","hex":"#fc9075"},{"key":"7/12","hex":"#ff8766"},{"key":"8/4","hex":"#ecbdb2"},{"key":"8/6","hex":"#fdb7a5"},{"key":"8/12","hex":"#ffa07b"},{"key":"9/2","hex":"#f2dfda"},{"key":"9/12","hex":"#ffb996"},{"key":"1/100","hex":"#d27c69"},{"key":"2/100","hex":"#f09680"},{"key":"3/100","hex":"#ffffff"},{"key":"4/100","hex":"#F3E8E5"},{"key":"5/100","hex":"#F3E8E5"},{"key":"6/100","hex":"#270500"}],"dominate_color":{"hex":"#764942","hsv":[8.457214026152265,44.19065636659835,46.253718009354148]},"custom_cover":"https://weread-1258476243.file.myqcloud.com/bookalphacover/143/30182143/s_30182143.jpg","custom_rec_cover":"https://weread-1258476243.file.myqcloud.com/bookreccover/143/30182143/s_30182143.jpg","colorsPure":["#eb6d4f","#ff8766"]}}}