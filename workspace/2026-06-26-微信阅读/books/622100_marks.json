{"synckey":1603978840,"updated":[{"bookId":"622100","bookmarkId":"622100_7_2178-2224","chapterUid":7,"markText":"成功的产品经理需要具备从财务知识到市场预测，再到合理定价以及运作有效性等方面切实的商业感觉。","range":"2178-2224","createTime":1603978840,"type":1},{"bookId":"622100","bookmarkId":"622100_7_1975-2025","chapterUid":7,"markText":"产品经理的工作是监督产品线或服务线的方方面面，以创造和提供良好的顾客满意度，同时为公司带来长期价值。","range":"1975-2025","createTime":1603978821,"type":1},{"bookId":"622100","bookmarkId":"622100_7_1555-1628","chapterUid":7,"markText":"有些公司把产品管理作为专注于产品开发的上游活动，而不是专注于营销和产品生命周期管理的下游活动。不过，绝大多数产品经理同时负有上游和下游的管理职责。","range":"1555-1628","createTime":1603978799,"type":1}],"removed":[],"chapters":[{"title":"第1章 产品经理工作的多面特性及其运作","chapterUid":7,"chapterIdx":7}],"book":{"bookId":"622100","version":1387896191,"format":"epub","soldout":1,"bookStatus":1,"cover":"https://wfqqreader-1252317822.image.myqcloud.com/cover/100/622100/s_622100.jpg","title":"产品经理手册（原书第4版）","author":"哥乔斯","coverBoxInfo":{"blurhash":"K6RfRZaK~q%OV@aeMwRQNH","colors":[{"key":"1/4","hex":"#201c17"},{"key":"1/6","hex":"#201c17"},{"key":"1/8","hex":"#201c17"},{"key":"2/4","hex":"#34302c"},{"key":"2/6","hex":"#34302c"},{"key":"2/8","hex":"#34302c"},{"key":"3/4","hex":"#4c4741"},{"key":"3/6","hex":"#4c4741"},{"key":"3/8","hex":"#4c4741"},{"key":"3/12","hex":"#4c4741"},{"key":"4/6","hex":"#655f59"},{"key":"4/10","hex":"#655f59"},{"key":"4/4","hex":"#655f59"},{"key":"5/10","hex":"#7e7972"},{"key":"5/4","hex":"#7e7972"},{"key":"5/8","hex":"#7e7972"},{"key":"6/4","hex":"#98938c"},{"key":"6/6","hex":"#98938c"},{"key":"6/8","hex":"#98938c"},{"key":"6/12","hex":"#98938c"},{"key":"7/8","hex":"#b2ada5"},{"key":"7/10","hex":"#b2ada5"},{"key":"7/12","hex":"#b2ada5"},{"key":"8/4","hex":"#ccc7bf"},{"key":"8/6","hex":"#ccc7bf"},{"key":"8/12","hex":"#ccc7bf"},{"key":"9/2","hex":"#e7e2da"},{"key":"9/12","hex":"#e7e2da"},{"key":"1/100","hex":"#98938c"},{"key":"2/100","hex":"#b2ada5"},{"key":"3/100","hex":"#ffffff"},{"key":"4/100","hex":"#F3EDE5"},{"key":"5/100","hex":"#F3EDE5"},{"key":"6/100