{"synckey":1702214808,"updated":[{"bookId":"3300055219","bookmarkId":"3300055219_6_2074-2143","createTime":1702214808,"chapterUid":6,"colorStyle":3,"type":1,"markText":"本章主要观点为你的人生是你体验的总和。也就是说，你人生里做的每一件事——你每天、每周、每月、每年及一生仅一次的所有体验——都决定了你是谁。","range":"2074-2143"},{"bookId":"3300055219","bookmarkId":"3300055219_5_12668-12752","createTime":1691192183,"chapterUid":5,"colorStyle":2,"type":1,"markText":"现在就开始积极思考你想要获得的人生体验和想要经历的次数。体验有大有小，有免费的，有花钱的，有慈善的，有享乐的，但建议你思考一下你真正想从人生中获得哪些有意义的难忘体验。","range":"12668-12752"},{"bookId":"3300055219","bookmarkId":"3300055219_5_3671-3740","createTime":1683942449,"chapterUid":5,"colorStyle":2,"type":1,"markText":"从你的体验中获得最大充实感，利用你的资源合理安排时间与金钱，让价值最大化，这就是你人生的最优解。把握好那些关键决定，你就掌控了自己的人生。","range":"3671-3740"},{"bookId":"3300055219","bookmarkId":"3300055219_5_3534-3565","createTime":1683942440,"chapterUid":5,"colorStyle":2,"type":1,"markText":"为了总体上增加你人生的充实感，在合适的年龄获得各种体验很重要。","range":"3534-3565"},{"bookId":"3300055219","bookmarkId":"3300055219_5_2066-2108","createTime":1683897850,"chapterUid":5,"colorStyle":2,"type":1,"markText":"有些体验只能在特定时间享受：大多数人无法在90多岁去滑水(water-skiing)","range":"2066-2108"},{"bookId":"3300055219","bookmarkId":"3300055219_5_2115-2156","createTime":1683897842,"chapterUid":5,"colorStyle":2,"type":1,"markText":"尽管我们每个人都至少有可能在未来赚更多钱，但我们绝对无法回到过去并夺回逝去的时间。","range":"2115-2156"},{"bookId":"3300055219","bookmarkId":"3300055219_5_1793-1809","createTime":1683897823,"chapterUid":5,"colorStyle":2,"type":1,"markText":"如何将充实感最大化，将浪费最小化","range":"1793-1809"},{"bookId":"3300055219","bookmarkId":"3300055219_5_1451-1532","createTime":1683897811,"chapterUid":5,"colorStyle":2,"type":1,"markText":"太多人延迟太久，或干脆无限拖延。他们一直拖着不去做想做的事，直到后悔莫及，想着等攒够钱了再去体验，却永远享受不到。抱着人生无限的态度生活，是没有远见、极度短视的。","range":"1451-1532"},{"bookId":"3300055219","bookmarkId":"3300055219_4_647-678","createTime":1683889233,"chapterUid":4,"colorStyle":2,"type":1,"markText":"我们都要生存，但是我们想要的不仅仅是生存，我们希望真正地生活。","range":"647-678"},{"bookId":"3300055219","bookmarkId":"3300055219_4_718-754","createTime":1683889232,"chapterUid":4,"colorStyle":2,"type":1,"markText":"人生须尽兴，而不仅是图存活。本书不是教你如何增长财富，而是如何充实人生。","range":"718-754"}],"removed":[],"chapters":[{"title":"1 极致人生","chapterUid":5,"chapterIdx":5},{"title":"写在前面","chapterUid":4,"chapterIdx":4},{"title":"2 投资体验","chapterUid":6,"chapterIdx":6}],"book":{"bookId":"3300055219","version":1990412437,"format":"epub","soldout":1,"bookStatus":1,"cover":"https://cdn.weread.qq.com/weread/cover/35/cpplatform_f4wzbjebzrn5yor7gi578h/s_cpplatform_f4wzbjebzrn5yor7gi578h1681367860.jpg","title":"最优解人生","author":"比尔·帕金斯","coverBoxInfo":{"blurhash":"KtHWDzs,j@t+WCoK0hR:WE","colors":[{"key":"1/4","hex":"#001f34"},{"key":"1/6","hex":"#00203f"},{"key":"1/8","hex":"#00214c"},{"key":"2/4","hex":"#113449"},{"key":"2/6","hex":"#003556"},{"key":"2/8","hex":"#003663"},{"key":"3/4","hex":"#274b63"},{"key":"3/6","hex":"#004d6f"},{"key":"3/8","hex":"#004e7c"},{"key":"3/12","hex":"#005196"},{"key":"4/6","hex":"#2d6586"},{"key":"4/10","hex":"#0069a1"},{"key":"4/4","hex":"#43647a"},{"key":"5/10","hex":"#0083bb"},{"key":"5/4","hex":"#5d7e93"},{"key":"5/8","hex":"#2981ad"},{"key":"6/4","hex":"#7898ac"},{"key":"6/6","hex":"#649aba"},{"key":"6/8","hex":"#4b9cc8"},{"key":"6/12","hex":"#009fe4"},{"key":"7/8","hex":"#66b6e2"},{"key":"7/10","hex":"#3db8f2"},{"key":"7/12","hex":"#00bbff"},{"key":"8/4","hex":"#aacde1"},{"key":"8/6","hex":"#96cff0"},{"key":"8/12","hex":"#00d7ff"},{"key":"9/2","hex":"#d6e5ed"},{"key":"9/12","hex":"#00f4ff"},{"key":"1/100","hex":"#4b9cc8"},{"key":"2/100","hex":"#66b6e2"},{"key":"3/100","hex":"#ffffff"},{"key":"4/100","hex":"#E5ECF3"},{"key":"5/100","hex":"#E5ECF3"},{"key":"6/100","hex":"#001927"}],"dominate_color":{"hex":"#7ebbde","hsv":[202.10346209146449,42.92150624351941,86.88810407933568]},"custom_cover":"https://weread-1258476243.file.myqcloud.com/bookalphacover/219/3300055219/s_3300055219.jpg","custom_rec_cover":"https://weread-1258476243.file.myqcloud.com/bookreccover/219/3300055219/s_3300055219.jpg","colorsPure":["#009fe4","#