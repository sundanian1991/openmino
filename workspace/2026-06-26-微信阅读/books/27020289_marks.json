{"synckey":1592520686,"updated":[{"bookId":"27020289","bookmarkId":"27020289_4_1208-1358","chapterUid":4,"markText":"每家企业都有一个生命周期，从起步、成长、成熟到衰落，每个阶段都要面临不同的问题。比如，起步阶段，最重要的是让产品落地，让客户接受产品；成长阶段，最重要的是快速扩大市场份额，将客户紧紧掌握在手中；成熟阶段，最重要的是控制成本，最大化地收割利润；衰落阶段，公司必须尽快寻找新的产品，再塑新的业务生命周期。","range":"1208-1358","createTime":1592520686,"type":1}],"removed":[],"chapters":[{"title":"第1章 资本游戏","chapterUid":4,"chapterIdx":4}],"book":{"bookId":"27020289","version":1496483955,"format":"epub","soldout":0,"bookStatus":1,"cover":"https://cdn.weread.qq.com/weread/cover/86/YueWen_27020289/s_YueWen_27020289.jpg","title":"资本游戏：企业生存与成长的资本运作之道","author":"徐友斌","coverBoxInfo":{"blurhash":"KKSF;Is;_4t8ayWA-=ayM_","colors":[{"key":"1/4","hex":"#291a00"},{"key":"1/6","hex":"#2e1900"},{"key":"1/8","hex":"#321800"},{"key":"2/4","hex":"#3d2f04"},{"key":"2/6","hex":"#412f00"},{"key":"2/8","hex":"#442e00"},{"key":"3/4","hex":"#54461e"},{"key":"3/6","hex":"#584600"},{"key":"3/8","hex":"#5b4500"},{"key":"3/12","hex":"#604400"},{"key":"4/6","hex":"#735e15"},{"key":"4/10","hex":"#775d00"},{"key":"4/4","hex":"#6e5f30"},{"key":"5/10","hex":"#947700"},{"key":"5/4","hex":"#887948"},{"key":"5/8","hex":"#927701"},{"key":"6/4","hex":"#a29360"},{"key":"6/6","hex":"#a89245"},{"key":"6/8","hex":"#ac9224"},{"key":"6/12","hex":"#b29100"},{"key":"7/8","hex":"#c7ac41"},{"key":"7/10","hex":"#cbac13"},{"key":"7/12","hex":"#ceab00"},{"key":"8/4","hex":"#d6c891"},{"key":"8/6","hex":"#dcc876"},{"key":"8/12","hex":"#e9c600"},{"key":"9/2","hex":"#ece3c3"},{"key":"9/12","hex":"#ffe221"},{"key":"1/100","hex":"#ac9224"},{"key":"2/100","hex":"#c7ac41"},{"key":"3/100","hex":"#ffffff"},{"key":"4/100","hex":"#F3F1E5"},{"key":"5/100","hex":"#F3F1E5"},{"key":"6/100","hex":"#271E00"}],"dominate_color":{"hex":"#d9d3be","hsv":[45.419233130893328,12.42600566572238,85.14589235127478]},"custom_cover":"https://weread-1258476243.file.myqcloud.com/bookalphacover/289/27020289/s_27020289.jpg","custom_rec_cover":"https://weread-1258476243.file.myqcloud.com/boo