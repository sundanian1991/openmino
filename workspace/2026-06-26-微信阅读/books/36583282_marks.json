{"synckey":1618202633,"updated":[{"bookId":"36583282","bookmarkId":"36583282_11_864-946","chapterUid":11,"markText":"从财务角度来看，CEO应该关注公司的四个方面：收入增长、利润（率）、现金净流入和资产回报率。收入是一切利润的来源，而利润体现了收入的质量，现金流则体现了利润的质量。","range":"864-946","createTime":1618202633,"type":1},{"bookId":"36583282","bookmarkId":"36583282_3_1340-1438","chapterUid":3,"markText":"财务人员也可以从这本书中学习如何与经营者进行沟通交流。财务人员要帮助经营者建立财务仪表盘，而不是仅仅把原始的财务报表丢给经营者。用财务管理的话来说，报表只是“原材料”，而经营者需要的是“产成品”。","range":"1340-1438","createTime":1616976509,"type":1}],"removed":[],"chapters":[{"title":"五、拉姆·查兰的仪表盘（财务的反馈模型）","chapterUid":11,"chapterIdx":11},{"title":"推荐序 Foreword","chapterUid":3,"chapterIdx":3}],"book":{"bookId":"36583282","version":1349723475,"format":"epub","soldout":0,"bookStatus":1,"cover":"https://cdn.weread.qq.com/weread/cover/31/YueWen_36583282/s_YueWen_36583282.jpg","title":"经营者的财务金三角","author":"闫静","coverBoxInfo":{"blurhash":"K38aQ]o~Ng-:oz9F0mV@sk","colors":[{"key":"1/4","hex":"#001e35"},{"key":"1/6","hex":"#001f40"},{"key":"1/8","hex":"#00204c"},{"key":"2/4","hex":"#16334a"},{"key":"2/6","hex":"#003457"},{"key":"2/8","hex":"#003564"},{"key":"3/4","hex":"#2b4a63"},{"key":"3/6","hex":"#0f4b70"},{"key":"3/8","hex":"#004d7d"},{"key":"3/12","hex":"#004f97"},{"key":"4/6","hex":"#346487"},{"key":"4/10","hex":"#0067a2"},{"key":"4/4","hex":"#47637b"},{"key":"5/10","hex":"#0081bc"},{"key":"5/4","hex":"#617d93"},{"key":"5/8","hex":"#3780ae"},{"key":"6/4","hex":"#7c97ac"},{"key":"6/6","hex":"#6a98bb"},{"key":"6/8","hex":"#569ac9"},{"key":"6/12","hex":"#009de6"},{"key":"7/8","hex":"#70b5e4"},{"key":"7/10","hex":"#51b6f4"},{"key":"7/12","hex":"#00b8ff"},{"key":"8/4","hex":"#aecce2"},{"key":"8/6","hex":"#9bcef2"},{"key":"8/12","hex":"#14d4ff"},{"key":"9/2","hex":"#d9e5ed"},{"key":"9/12","hex":"#46f1ff"},{"key":"1/100","hex":"#569ac9"},{"key":"2/100","hex":"#70b5e4"},{"key":"3/100","hex":"#ffffff"},{"key":"4/100","hex":"#E5ECF3"},{"key":"5/100","hex":"#E5ECF3"},{"key":"6/100","hex":"#001927"}],"dominate_color":{"hex":"#0393d3","hsv":[19