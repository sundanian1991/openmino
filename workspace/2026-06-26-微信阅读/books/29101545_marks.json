{"synckey":1650185315,"updated":[{"bookId":"29101545","bookmarkId":"29101545_6_2059-2186","chapterUid":6,"markText":"很多人上班之后就开始变胖，头号原因就是工作压力大。心理压力首先会导致肾上腺皮质醇指数升高，激发上班族的饮食欲望，以此来缓解压力；同时，压力还会导致新陈代谢减慢。摄入食物增多，新陈代谢减慢，加上长期久坐不动，自然容易发胖，而肥胖则会导致一系列心脑血管疾病。","range":"2059-2186","createTime":1650185315,"type":1}],"removed":[],"chapters":[{"title":"1 上班族，你的健康从办公室健身开始","chapterUid":6,"chapterIdx":6}],"book":{"bookId":"29101545","version":1478340792,"format":"epub","soldout":0,"bookStatus":1,"cover":"https://cdn.weread.qq.com/weread/cover/51/YueWen_29101545/s_YueWen_29101545.jpg","title":"办公室健身训练图解","author":"张冰 彭庆文 高岩","coverBoxInfo":{"blurhash":"KMIF3zM|9~^*RjNF0Kt6^+","colors":[{"key":"1/4","hex":"#0a1c35"},{"key":"1/6","hex":"#001c41"},{"key":"1/8","hex":"#001b4d"},{"key":"2/4","hex":"#21314b"},{"key":"2/6","hex":"#0f3158"},{"key":"2/8","hex":"#003165"},{"key":"3/4","hex":"#364864"},{"key":"3/6","hex":"#284872"},{"key":"3/8","hex":"#12497e"},{"key":"3/12","hex":"#004898"},{"key":"4/6","hex":"#456189"},{"key":"4/10","hex":"#1c62a3"},{"key":"4/4","hex":"#51617b"},{"key":"5/10","hex":"#407cbd"},{"key":"5/4","hex":"#6a7a94"},{"key":"5/8","hex":"#527bb0"},{"key":"6/4","hex":"#8494ad"},{"key":"6/6","hex":"#7995bc"},{"key":"6/8","hex":"#6d96ca"},{"key":"6/12","hex":"#4497e8"},{"key":"7/8","hex":"#86b0e5"},{"key":"7/10","hex":"#75b1f6"},{"key":"7/12","hex":"#5ab2ff"},{"key":"8/4","hex":"#b7c9e2"},{"key":"8/6","hex":"#aacaf4"},{"key":"8/12","hex":"#75ccff"},{"key":"9/2","hex":"#dce4ed"},{"key":"9/12","hex":"#8be9ff"},{"key":"1/100","hex":"#6d96ca"},{"key":"2/100","hex":"#86b0e5"},{"key":"3/100","hex":"#ffffff"},{"key":"4/100","hex":"#E5ECF3"},{"key":"5/100","hex":"#E5ECF3"},{"key":"6/100","hex":"#001927"}],"dominate_color":{"hex":"#8292aa","hsv":[216.050572276376,23.384817071690418,66.54996641661204]},"custom_cover":"https://weread-1258476243.file.myqcloud.com/bookalphacover/545/29101545/s_29101545.jpg","custom_rec_cover":"https://weread-1258476243.file.myqcloud.com/bookreccover/545/2910