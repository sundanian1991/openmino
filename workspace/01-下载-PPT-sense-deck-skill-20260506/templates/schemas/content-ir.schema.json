{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Jingge PPT Content IR",
  "type": "object",
  "required": ["title", "audience", "theme", "features", "slides"],
  "properties": {
    "title": { "type": "string" },
    "subtitle": { "type": "string" },
    "audience": { "type": "string" },
    "scenario": { "type": "string" },
    "tone": { "type": "string" },
    "language": { "type": "string" },
    "theme": { "type": "string" },
    "assets": {
      "type": "object",
      "properties": {
        "backgroundDecision": {
          "type": "object",
          "required": ["needed", "reason"],
          "properties": {
            "needed": { "type": "boolean" },
            "reason": { "type": "string" },
            "assetPlan": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "id": { "type": "string" },
                  "path": { "type": "string" },
                  "slides": { "type": "array", "items": { "type": "string" } },
                  "brief": { "type": "string" },
                  "style": { "type": "string" },
                  "aspectRatio": { "type": "string" }
                }
              }
            }
          }
        },
        "imageGeneration": {
          "type": "object",
          "properties": {
            "mode": { "enum": ["auto", "required", "off", "fallback-prompts"] },
            "providerHint": { "type": "string" },
            "preferRaster": { "type": "boolean" },
            "assetStrategy": { "enum": ["cinematic-images", "png-components", "svg-css-fallback", "hybrid"] },
            "providerConfig": {
              "type": "object",
              "properties": {
                "name": { "type": "string" },
                "mode": { "type": "string" },
                "model": { "type": "string" },
                "apiBaseEnv": { "type": "string" },
                "apiKeyEnv": { "type": "string" },
                "commandTemplate": { "type": "string" },
                "outputFormat": { "enum": ["png", "webp", "jpg", "jpeg"] },
                "supportsAlpha": { "type": "boolean" },
                "supportsImageReference": { "type": "boolean" },
                "fallbackStrategy": { "enum": ["image-prompts-json", "svg-css-fallback", "manual-assets"] }
              }
            },
            "svgPolicy": { "type": "string" }
          }
        },
        "spotIllustrations": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "path", "slides", "brief", "semanticUse"],
            "properties": {
              "id": { "type": "string" },
              "path": { "type": "string" },
              "slides": { "type": "array", "items": { "type": "string" } },
              "brief": { "type": "string" },
              "style": { "type": "string" },
              "placement": { "type": "string" },
              "size": { "enum": ["spot", "card", "rail", "hero-fragment", "background"] },
              "maxSlideWidth": { "type": "string" },
              "semanticUse": { "type": "string" },
              "alt": { "type": "string" },
              "fallback": { "type": "string" }
            }
          }
        },
        "firstThreeSlideTrial": {
          "type": "object",
          "properties": {
            "required": { "type": "boolean" },
            "status": { "enum": ["not-needed", "planned", "generated", "placed", "reviewed", "fallback-prompts"] },
            "slides": { "type": "array", "items": { "type": "string" } },
            "notes": { "type": "string" }
          }
        }
      }
    },
    "features": {
      "type": "object",
      "required": ["gesture", "presenterMode"],
      "properties": {
        "gesture": { "enum": ["off", "motion-lite", "mediapipe-hand"] },
        "presenterMode": { "type": "boolean" },
        "editable": { "type": "boolean" },
        "typstHandout": { "type": "boolean" }
      }
    },
    "decorAssets": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "path", "semanticUse"],
        "properties": {
          "id": { "type": "string" },
          "path": { "type": "string" },
          "source": { "type": "string" },
          "semanticUse": { "type": "string" },
          "fallback": { "type": "string" }
        }
      }
    },
    "sourceSummary": {
      "type": "object",
      "properties": {
        "thesis": { "type": "string" },
        "keyArguments": { "type": "array", "items": { "type": "string" } }
      }
    },
    "slides": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["role", "title", "layout", "theme", "visibleContent", "speakerNotes"],
        "properties": {
          "role": { "type": "string" },
          "title": { "type": "string" },
          "layout": { "type": "string" },
          "theme": { "type": "string" },
          "animations": { "type": "array", "items": { "type": "string" } },
          "canvasFx": { "type": ["string", "null"] },
          "decorAssets": { "type": "array", "items": { "type": "string" } },
          "editable": {
            "type": "object",
            "properties": {
              "text": { "type": "boolean" },
              "layout": { "type": "boolean" },
              "notes": { "type": "boolean" }
            }
          },
          "visibleContent": { "type": "object" },
          "speakerNotes": { "type": "string" }
        }
      }
    }
  }
}
