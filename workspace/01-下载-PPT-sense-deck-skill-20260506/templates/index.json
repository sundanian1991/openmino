{
  "name": "jingge-ppt-template-library",
  "version": "0.1.0",
  "workflow": "Read this index first, generate content IR, then select a theme, a full deck or single-page layouts, and optional animations before writing content.",
  "catalogs": {
    "themes": "themes/theme-catalog.json",
    "fullDecks": "full-decks/deck-catalog.json",
    "singlePageLayouts": "single-page-layouts/layout-catalog.json",
    "animations": "animations/animation-catalog.json"
  },
  "schemas": {
    "contentIr": "schemas/content-ir.schema.json",
    "template": "schemas/template.schema.json"
  },
  "contentIr": {
    "example": "content-ir/content-ir.example.json",
    "rule": "Generate content IR before rendering HTML, Typst, or export artifacts."
  },
  "runtime": {
    "slideLifecycle": "runtime/slide-lifecycle.js",
    "canvasFxRuntime": "runtime/canvas-fx-runtime.js",
    "editMode": "runtime/edit-mode.js",
    "gestureController": "features/gesture-controller.js",
    "lifecycleEvents": [
      "Reveal slidechanged",
      "deck:slidechange"
    ]
  },
  "exporters": {
    "html": "exporters/html",
    "pdf": "exporters/pdf",
    "typst": "exporters/typst"
  },
  "featureFlags": {
    "gesture": [
      "off",
      "motion-lite",
      "mediapipe-hand"
    ],
    "presenterMode": [
      true,
      false
    ],
    "editable": [
      true,
      false
    ],
    "typstHandout": [
      true,
      false
    ]
  },
  "targetLibraryShape": {
    "fullDecks": 19,
    "singlePageLayouts": 31,
    "cssAnimations": 27,
    "canvasFx": 20,
    "themes": 9
  },
