{
  "name": "likecodenex-joyspace",
  "description": "JoySpace 企业文档管理 MCP。支持文档搜索、读取、创建、目录管理、标签管理、分享、日程/任务关联。",
  "version": "1.0.0",
  "transport": "mcp",
  "baseUrl": "https://joyspace.jd.com",
  "auth": {
    "type": "sso",
    "loginUrl": "http://erp.jd.com",
    "failureStatus": "auth_required",
    "failureQuestionField": "__question__"
  },
  "namespace": "joyspace",
  "tools": [
    {
      "name": "search_recent_doc",
      "description": "搜索最近访问的 JoySpace 文档。",
      "parameters": {
        "type": "object",
        "properties": {
          "search": { "type": "string", "description": "搜索关键词" },
          "keyword": { "type": "string", "description": "搜索关键词（与 search 二选一）" },
          "start": { "type": "integer", "description": "分页起始位置" },
          "offset": { "type": "integer", "description": "分页偏移量（与 start 二选一）" },
          "length": { "type": "integer", "description": "每页数量" }
        }
      }
    },
    {
      "name": "search_in_team",
      "description": "在指定空间/目录内搜索文档。",
      "parameters": {
        "type": "object",
        "required": ["team_id"],
        "properties": {
          "team_id": { "type": "string", "description": "空间 ID，私人空间用 root" },
          "folder_id": { "type": "string", "description": "目录 ID，根目录用 root" },
          "search": { "type": "string" },
          "keyword": { "type": "string" },
          "start": { "type": "integer" },
          "offset": { "type": "integer" },
          "length": { "type": "integer" }
        }
      }
    },
    {
      "name": "similar_solution_search",
      "description": "搜索历史相似方案文档。",
      "parameters": {
        "type": "object",
        "properties": {
          "search": { "type": "string" },
          "start": { "type": "integer" },
          "offset": { "type": "integer" },
          "length": { "type": "integer" }
        }
      }
    },
    {
      "name": "list_received_doc",
      "description": "获取收到的分享文档列表。",
      "parameters": {
        "type": "object",
        "properties": {
          "unread": { "type": "integer", "description": "1=未读" },
          "search": { "type": "string" },
          "start": { "type": "integer" },
          "offset": { "type": "integer" },
          "length": { "type": "integer" }
        }
      }
    },
    {
      "name": "get_page_basic_info",
      "description": "获取文档基本信息。",
      "parameters": {
        "type": "object",
        "required": ["page_id"],
        "properties": {
          "page_id": { "type": "string" }
        }
      }
    },
    {
      "name": "get_normal_json_content",
      "description": "获取文档 JSON 内容。",
      "parameters": {
        "type": "object",
        "required": ["page_id"],
        "properties": {
          "page_id": { "type": "string" }
        }
      }
    },
    {
      "name": "joyspace.get_normal_markdown_content",
      "description": "获取文档 Markdown 内容。",
      "parameters": {
        "type": "object",
        "required": ["page_id"],
        "properties": {
          "page_id": { "type": "string" }
        }
      }
    },
    {
      "name": "summarize_and_outline",
      "description": "获取文档摘要和大纲。",
      "parameters": {
        "type": "object",
        "required": ["page_id"],
        "properties": {
          "page_id": { "type": "string" }
        }
      }
    },
    {
      "name": "joyspace.list_doc_by_page",
      "description": "分页列出空间/目录下的文档。",
      "parameters": {
        "type": "object",
        "required": ["team_id"],
        "properties": {
          "team_id": { "type": "string", "description": "空间 ID，私人空间用 root" },
          "folder_id": { "type": "string", "description": "目录 ID，根目录用 root" },
          "sort": { "type": "string" },
          "start": { "type": "integer" },
          "offset": { "type": "integer" },
          "length": { "type": "integer" }
        }
      }
    },
    {
      "name": "joyspace.list_folders",
      "description": "列出目录下的子目录。",
      "parameters": {
        "type": "object",
        "required": ["team_id"],
        "properties": {
          "team_id": { "type": "string" },
          "folder_id": { "type": "string" }
        }
      }
    },
    {
      "name": "joyspace.create_folder",
      "description": "创建目录。",
      "parameters": {
        "type": "object",
        "required": ["name", "team_id", "folder_id"],
        "properties": {
          "name": { "type": "string", "description": "目录名称" },
          "team_id": { "type": "string" },
          "folder_id": { "type": "string" }
        }
      }
    },
    {
      "name": "joyspace.get_folder_info",
      "description": "获取目录信息。",
      "parameters": {
        "type": "object",
        "required": ["folder_id"],
        "properties": {
          "folder_id": { "type": "string" }
        }
      }
    },
    {
      "name": "joyspace.rename_folder",
      "description": "重命名目录。",
      "parameters": {
        "type": "object",
        "required": ["folder_id", "name"],
        "properties": {
          "folder_id": { "type": "string" },
          "name": { "type": "string" }
        }
      }
    },
    {
      "name": "joyspace.move_to",
      "description": "批量移动文档到目录，单次不超过 50 个。",
      "parameters": {
        "type": "object",
        "required": ["team_id", "folder_id", "page_ids"],
        "properties": {
          "team_id": { "type": "string" },
          "folder_id": { "type": "string" },
          "page_ids": {
            "type": "array",
            "items": { "type": "string" },
            "maxItems": 50
          }
        }
      }
    },
    {
      "name": "joyspace.list_tags",
      "description": "列出所有标签。",
      "parameters": { "type": "object", "properties": {} }
    },
    {
      "name": "joyspace.create_tag",
      "description": "创建标签。",
      "parameters": {
        "type": "object",
        "required": ["name"],
        "properties": { "name": { "type": "string" } }
      }
    },
    {
      "name": "joyspace.rename_tag",
      "description": "重命名标签。",
      "parameters": {
        "type": "object",
        "required": ["tag_id", "name"],
        "properties": {
          "tag_id": { "type": "string" },
          "name": { "type": "string" }
        }
      }
    },
    {
      "name": "joyspace.delete_tag",
      "description": "删除标签。",
      "parameters": {
        "type": "object",
        "required": ["tag_id"],
        "properties": { "tag_id": { "type": "string" } }
      }
    },
    {
      "name": "joyspace.get_page_tag_list",
      "description": "获取文档的标签列表。",
      "parameters": {
        "type": "object",
        "required": ["page_id"],
        "properties": { "page_id": { "type": "string" } }
      }
    },
    {
      "name": "joyspace.page_add_tag_ref",
      "description": "为文档添加标签。",
      "parameters": {
        "type": "object",
        "required": ["page_id", "tag_id"],
        "properties": {
          "page_id": { "type": "string" },
          "tag_id": { "type": "string" }
        }
      }
    },
    {
      "name": "joyspace.page_remove_tag_ref",
      "description": "移除文档的标签。",
      "parameters": {
        "type": "object",
        "required": ["page_id", "tag_id"],
        "properties": {
          "page_id": { "type": "string" },
          "tag_id": { "type": "string" }
        }
      }
    },
    {
      "name": "joyspace.search_team",
      "description": "搜索空间/团队。",
      "parameters": {
        "type": "object",
        "required": ["search"],
        "properties": { "search": { "type": "string" } }
      }
    },
    {
      "name": "joyspace.search_docs_by_tag",
      "description": "按标签搜索文档。",
      "parameters": {
        "type": "object",
        "required": ["tag_keyword"],
        "properties": {
          "tag_keyword": { "type": "string" },
          "search": { "type": "string" },
          "start": { "type": "integer" },
          "offset": { "type": "integer" },
          "length": { "type": "integer" }
        }
      }
    },
    {
      "name": "joyspace.search_employee",
      "description": "搜索员工，用于分享文档。",
      "parameters": {
        "type": "object",
        "required": ["search"],
        "properties": {
          "search": { "type": "string" },
          "keyword": { "type": "string" },
          "start": { "type": "integer" },
          "offset": { "type": "integer" },
          "length": { "type": "integer" }
        }
      }
    },
    {
      "name": "joyspace.share_to_contact",
      "description": "分享文档给联系人。",
      "parameters": {
        "type": "object",
        "required": ["page_id", "employee_id"],
        "properties": {
          "page_id": { "type": "string" },
          "employee_id": { "type": "string" },
          "content": { "type": "string", "description": "附言" }
        }
      }
    },
    {
      "name": "search.user_receive_share",
      "description": "查询收到的分享（带时间筛选）。",
      "parameters": {
        "type": "object",
        "properties": {
          "unread": { "type": "integer" },
          "share_timestamp_start": { "type": "integer", "description": "13位毫秒时间戳" }
        }
      }
    },
    {
      "name": "search.get_report_to_me",
      "description": "查询汇报给我的文档。",
      "parameters": {
        "type": "object",
        "properties": { "params": { "type": "object" } }
      }
    },
    {
      "name": "joyspace.directory_qa",
      "description": "基于目录内容的 AI 问答。",
      "parameters": {
        "type": "object",
        "required": ["content"],
        "properties": {
          "content": { "type": "string", "description": "问题内容" },
          "page_id": { "type": "string" },
          "folder_id": { "type": "string" },
          "team_id": { "type": "string" }
        }
      }
    },
    {
      "name": "joyspace.get_doc_related_schedules",
      "description": "获取文档关联的日程。",
      "parameters": {
        "type": "object",
        "required": ["page_id"],
        "properties": { "page_id": { "type": "string" } }
      }
    },
    {
      "name": "joyspace.get_tasks_from_received",
      "description": "从收到的分享中提取任务。",
      "parameters": {
        "type": "object",
        "properties": {
          "share_timestamp_start": { "type": "integer", "description": "13位毫秒时间戳" }
        }
      }
    },
    {
      "name": "joyspace.get_tasks_from_pages",
      "description": "从指定文档中提取任务。",
      "parameters": {
        "type": "object",
        "required": ["page_ids"],
        "properties": {
          "page_ids": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    {
      "name": "joyspace.get_doc_related_work",
      "description": "获取文档关联的工作项。",
      "parameters": {
        "type": "object",
        "required": ["page_id"],
        "properties": { "page_id": { "type": "string" } }
      }
    },
    {
      "name": "joyspace.get_joyday_relation",
      "description": "获取文档关联的日历事件。",
      "parameters": {
        "type": "object",
        "required": ["page_id"],
        "properties": { "page_id": { "type": "string" } }
      }
    },
    {
      "name": "create_doc_routing",
      "description": "创建 JoySpace 文档。创建后展示链接 https://joyspace.jd.com/pages/{page_id}",
      "parameters": {
        "type": "object",
        "properties": {
          "title": { "type": "string" },
          "team_id": { "type": "string", "description": "空间 ID，私人空间用 root" },
          "folder_id": { "type": "string", "description": "目录 ID，根目录用 root" },
          "doc_type": { "type": "string" },
          "content": { "type": "string", "description": "文档内容，Markdown 格式" }
        }
      }
    },
    {
      "name": "publish_comment",
      "description": "发布文档评论。",
      "parameters": {
        "type": "object",
        "required": ["page_id", "content"],
        "properties": {
          "page_id": { "type": "string" },
          "content": { "type": "string" }
        }
      }
    }
  ]
}
