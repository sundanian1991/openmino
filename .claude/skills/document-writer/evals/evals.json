{
  "skill": "document-writer",
  "version": "1.0",
  "lastUpdated": "2026-03-12",
  "description": "公文起草质量评估框架",
  "dimensions": [
    {
      "name": "场景适配性",
      "weight": 0.30,
      "checks": [
        {
          "id": "scenario-match",
          "name": "场景匹配",
          "description": "正确识别场景类型（向上审批/向上汇报/供应商管理/内部协调/整改通知）",
          "type": "boolean",
          "passCriteria": "场景识别准确，模板选择正确"
        },
        {
          "id": "posture-correct",
          "name": "姿态正确",
          "description": "向上谦逊（建议/拟）、向下专业（务必/请于）、平级协作（协商/能否）",
          "type": "boolean",
          "passCriteria": "姿态与场景匹配，无姿态错误"
        },
        {
          "id": "forbidden-words",
          "name": "禁用词检查",
          "description": "向上审批禁用"必须/务必"，供应商管理禁用"可能/也许"",
          "type": "boolean",
          "passCriteria": "无禁用词出现"
        }
      ]
    },
    {
      "name": "格式规范性",
      "weight": 0.25,
      "checks": [
        {
          "id": "paragraph-logic",
          "name": "段落逻辑",
          "description": "段落开始用**加粗关键词**标识，逻辑清晰",
          "type": "boolean",
          "passCriteria": "每段有关键词标识，逻辑连贯"
        },
        {
          "id": "no-decoration",
          "name": "无视觉装饰",
          "description": "不使用分割线、边框等视觉装饰",
          "type": "boolean",
          "passCriteria": "无分割线、边框等装饰元素"
        },
        {
          "id": "data-structured",
          "name": "数据结构化",
          "description": "时间、人员、数据等用列表/表格清晰呈现",
          "type": "boolean",
          "passCriteria": "数据用列表/表格呈现，便于扫视"
        },
        {
          "id": "spacing-comfortable",
          "name": "留白适度",
          "description": "段落之间空一行，阅读节奏舒适",
          "type": "boolean",
          "passCriteria": "段落间距一致，阅读舒适"
        },
        {
          "id": "action-request",
          "name": "行动请求明确",
          "description": "结尾有明确的行动请求或请示",
          "type": "boolean",
          "passCriteria": "结尾有明确行动请求"
        }
      ]
    },
    {
      "name": "内容质量",
      "weight": 0.30,
      "checks": [
        {
          "id": "data-expression",
          "name": "数据化表达",
          "description": "模糊描述已转换为数据化表达（"效果不错"→"转化率提升 15%"）",
          "type": "boolean",
          "passCriteria": "无模糊描述，所有表述数据化"
        },
        {
          "id": "risk-response",
          "name": "风险对应方案",
          "description": "每个风险都有应对措施",
          "type": "boolean",
          "passCriteria": "所有风险有对应应对方案"
        },
        {
          "id": "content-complete",
          "name": "内容完整",
          "description": "包含：称呼、目的、事实、分析、建议、行动请求",
          "type": "boolean",
          "passCriteria": "六部分结构完整"
        },
        {
          "id": "logic-clear",
          "name": "逻辑清晰",
          "description": "段落间用过渡词连接（"基于上述..."、"综合评估..."）",
          "type": "boolean",
          "passCriteria": "过渡自然，逻辑连贯"
        }
      ]
    },
    {
      "name": "语言质量",
      "weight": 0.15,
      "checks": [
        {
          "id": "professional-language",
          "name": "语言专业",
          "description": "用词准确专业，不口语化",
          "type": "boolean",
          "passCriteria": "无口语化表达"
        },
        {
          "id": "concise",
          "name": "简洁",
          "description": "一句一信息，不啰嗦",
          "type": "boolean",
          "passCriteria": "无冗余表述"
        },
        {
          "id": "no-ai-flavor",
          "name": "无 AI 味",
          "description": "无"值得注意的是"、"综上所述"、"具有重要意义"等 AI 套话",
          "type": "boolean",
          "passCriteria": "无 AI 套话，语言自然"
        }
      ]
    }
  ],
  "scoring": {
    "method": "weighted",
    "thresholds": {
      "excellent": 0.9,
      "good": 0.75,
      "pass": 0.6,
      "fail": 0.6
    }
  },
  "userSatisfaction": {
    "track": true,
    "metrics": [
      {
        "name": "直接可用率",
        "description": "用户无需修改或仅微调即可直接使用的比例",
        "target": "≥80%"
      },
      {
        "name": "修改次数",
        "description": "平均需要修改的次数",
        "target": "≤2 次"
      },
      {
        "name": "用户满意度",
        "description": "用户主观评分（1-5 分）",
        "target": "≥4.0"
      }
    ]
  },
  "continuousImprovement": {
    "reviewCycle": "weekly",
    "actions": [
      "每周回顾评估结果，识别低分项",
      "收集用户反馈，更新检查项和模板",
      "每月迭代一次评估标准"
    ]
  }
}
