{
  "skill": "weekly-report",
  "version": "1.0",
  "lastUpdated": "2026-03-12",
  "description": "周报质量评估框架",
  "dimensions": [
    {
      "name": "格式规范性",
      "weight": 0.25,
      "checks": [
        {
          "id": "structure-complete",
          "name": "结构完整",
          "description": "必须包含：本周主线、核心进展、风险与待协同、待决策事项",
          "type": "boolean",
          "passCriteria": "四个章节全部存在"
        },
        {
          "id": "pure-text-format",
          "name": "纯文字格式",
          "description": "不使用表格、分割线等装饰，方便 Excel 粘贴",
          "type": "boolean",
          "passCriteria": "无表格、无分割线、无 emoji 装饰"
        },
        {
          "id": "hierarchy-clear",
          "name": "层级清晰",
          "description": "用 - 和缩进表示层级，关键词前置",
          "type": "boolean",
          "passCriteria": "层级缩进一致，关键词可快速扫视"
        }
      ]
    },
    {
      "name": "内容质量",
      "weight": 0.35,
      "checks": [
        {
          "id": "mainline-clear",
          "name": "主线清晰",
          "description": "本周主线≤30 字，一句话说明本周最重要的结果",
          "type": "stringLength",
          "maxLength": 30
        },
        {
          "id": "evidence-backed",
          "name": "证据补全",
          "description": "每条核心进展必须有可验证依据（数据对比/上线记录/会议纪要/对方确认）",
          "type": "ratio",
          "passCriteria": "≥80% 的进展有证据支撑"
        },
        {
          "id": "data-specific",
          "name": "数据具体",
          "description": "有数字必须保留（3 人、15 人、2 家、9 号），有时间必须明确（3 月、上周、W09）",
          "type": "boolean",
          "passCriteria": "所有数字和时间都具体明确，无模糊表述"
        },
        {
          "id": "no-empty-phrases",
          "name": "无空话",
          "description": "无"持续推进"、"沟通对齐"、"跟进中"等空话，已转换为具体动作",
          "type": "boolean",
          "passCriteria": "无空话，所有描述都是可验证的动作或结果"
        }
      ]
    },
    {
      "name": "语言专业性",
      "weight": 0.25,
      "checks": [
        {
          "id": "professional-language",
          "name": "语言专业",
          "description": "用词准确，不口语化（如"选定"而非"确定了"，"人力储备流失"而非"被挖"）",
          "type": "boolean",
          "passCriteria": "无口语化表达，用词专业准确"
        },
        {
          "id": "no-subjective-words",
          "name": "无主观词",
          "description": "无"我们"、"我"等主观词",
          "type": "boolean",
          "passCriteria": "无第一人称主观词"
        },
        {
          "id": "no-fuzzy-words",
          "name": "无模糊词",
          "description": "无"大概"、"可能"、"也许"等模糊词",
          "type": "boolean",
          "passCriteria": "无模糊词，所有表述确定"
        }
      ]
    },
    {
      "name": "口述稿质量",
      "weight": 0.15,
      "checks": [
        {
          "id": "oral-structure",
          "name": "结构清晰",
          "description": "口述稿包含：核心进展（3 件事）、风险项、待决策",
          "type": "boolean",
          "passCriteria": "三部分结构完整"
        },
        {
          "id": "oral-timing",
          "name": "时长控制",
          "description": "口述稿 400-500 字，3 分钟内可读完",
          "type": "stringLength",
          "minLength": 400,
          "maxLength": 500
        },
        {
          "id": "oral-keywords",
          "name": "关键词前置",
          "description": "每段开头有关键词，方便扫视",
          "type": "boolean",
          "passCriteria": "每段关键词清晰可识别"
        }
      ]
    }
  ],
  "scoring": {
    "method": "weighted",
    "thresholds": {
      "excellent": 0.9,
      "good": 0.75,
      "pass": 0.6,
      "fail": 0.6
    }
  },
  "userSatisfaction": {
    "track": true,
    "metrics": [
      {
        "name": "直接可用率",
        "description": "用户无需修改或仅微调即可直接使用的比例",
        "target": "≥80%"
      },
      {
        "name": "修改次数",
        "description": "平均需要修改的次数",
        "target": "≤2 次"
      },
      {
        "name": "用户满意度",
        "description": "用户主观评分（1-5 分）",
        "target": "≥4.0"
      }
    ]
  },
  "continuousImprovement": {
    "reviewCycle": "weekly",
    "actions": [
      "每周回顾评估结果，识别低分项",
      "收集用户反馈，更新检查项",
      "每月迭代一次评估标准"
    ]
  }
}
