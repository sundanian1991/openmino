    # Card number
    run("officecli", "add", OUTPUT, "/slide[3]", "--type", "shape",
        "--prop", f"name=#s3-num{i+1}", "--prop", "text=" + str(i+1),
        "--prop", "font=Arial Black", "--prop", "size=48", "--prop", "bold=true",
        "--prop", f"color={color}", "--prop", f"x={x+0.5}cm", "--prop", "y=5.5cm",
        "--prop", "width=2cm", "--prop", "height=2cm", "--prop", "fill=none")
    
    # Card title
