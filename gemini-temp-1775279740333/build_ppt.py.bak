actions = [
    "1. 不接靶子，不说"激励确实有问题"",
    "2. 回归根本原因，指出"交接期信息真空"",
    "3. 用真实数据对冲情绪化数字",
    "4. 保护团队安全感"
]

for i, action in enumerate(actions):
    run("officecli", "add", OUTPUT, "/slide[7]", "--type", "shape",
        "--prop", f"name=#s7-action{i+1}", "--prop", "text=" + action,
        "--prop", "font=Microsoft YaHei", "--prop", "size=20",
        "--prop", "color=ffffff", "--prop", "x=6cm", "--prop", f"y={11+i*1.8}cm",
        "--prop", "width=28cm", "--prop", "height=1.5cm", "--prop", "fill=none")

# Final verification
helper("verify", OUTPUT, 7)
print("  ✓ Slide 7 complete")

# ==================== FINAL CHECK ====================
print("\n
" + "=" * 50)
print("Final verification...")
helper("final-check", OUTPUT)

print("\n
" + "=" * 50)
print(f"✅ Build complete! Open {OUTPUT} to see morph animations.")
print("=" * 50)
