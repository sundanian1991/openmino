#!/usr/bin/env python3
"""
刘乾坤"带节奏"事件分析 PPT 构建脚本
风格: dark--premium-navy (专业分析风格)
"""
import subprocess
import sys
import os

def run(*args):
    """Execute officecli command"""
    result = subprocess.run(list(args), capture_output=True, text=True)
    if result.returncode != 0:
        print(f"Error: {result.stderr}")
        sys.exit(result.returncode)
    return result

# Load helper functions
SCRIPT_DIR = os.path.dirname(os.path.abspath(__file__))
HELPER_PATH = os.path.join(SCRIPT_DIR, ".gemini/skills/morph-ppt/reference", "morph-helpers.py")

def helper(*args):
    """Call helper script"""
    result = subprocess.run([sys.executable, HELPER_PATH] + [str(a) for a in args], 
                          capture_output=True, text=True)
    if result.returncode != 0:
        print(f"Helper error: {result.stderr}")
        sys.exit(result.returncode)
    return result

OUTPUT = "刘乾坤带节奏事件分析.pptx"

# Create new presentation
print("=" * 50)
print("Creating PPT: 刘乾坤带节奏事件分析")
print("=" * 50)
run("officecli", "create", OUTPUT)

# ==================== SLIDE 1: HERO ====================
print("[S1] Building Hero Slide...")
run("officecli", "add", OUTPUT, "/", "--type", "slide")
run("officecli", "set", OUTPUT, "/slide[1]", "--prop", "background=1a1f2e")

# Scene actors - navy premium style
# Large accent ring
run("officecli", "add", OUTPUT, "/slide[1]", "--type", "shape",
    "--prop", "name=!!ring-accent", "--prop", "preset=ellipse",
    "--prop", "fill=3b82f6", "--prop", "opacity=0.15",
    "--prop", "x=2cm", "--prop", "y=2cm",
    "--prop", "width=12cm", "--prop", "height=12cm")

# Small dot accent
run("officecli", "add", OUTPUT, "/slide[1]", "--type", "shape",
    "--prop", "name=!!dot-main", "--prop", "preset=ellipse",
    "--prop", "fill=60a5fa", "--prop", "opacity=0.8",
    "--prop", "x=28cm", "--prop", "y=4cm",
    "--prop", "width=1.5cm", "--prop", "height=1.5cm")

# Line accent
run("officecli", "add", OUTPUT, "/slide[1]", "--type", "shape",
    "--prop", "name=!!line-top", "--prop", "preset=rect",
    "--prop", "fill=60a5fa", "--prop", "opacity=0.6",
    "--prop", "x=25cm", "--prop", "y=2cm",
    "--prop", "width=6cm", "--prop", "height=0.3cm")

# Main title
run("officecli", "add", OUTPUT, "/slide[1]", "--type", "shape",
    "--prop", "name=#s1-title", "--prop", "text=带节奏事件分析",
    "--prop", "font=Microsoft YaHei", "--prop", "size=72", "--prop", "bold=true",
    "--prop", "color=ffffff", "--prop", "x=8cm", "--prop", "y=6cm",
    "--prop", "width=26cm", "--prop", "height=4cm", "--prop", "fill=none")

# Subtitle
run("officecli", "add", OUTPUT, "/slide[1]", "--type", "shape",
    "--prop", "name=#s1-subtitle", "--prop", "text=刘乾坤开门红激励预警行为深度拆解",
    "--prop", "font=Microsoft YaHei", "--prop", "size=32",
    "--prop", "color=94a3b8", "--prop", "x=8cm", "--prop", "y=10.5cm",
    "--prop", "width=26cm", "--prop", "height=2cm", "--prop", "fill=none")

# Date tag
run("officecli", "add", OUTPUT, "/slide[1]", "--type", "shape",
    "--prop", "name=#s1-date", "--prop", "text=2026年3月29日",
    "--prop", "font=Microsoft YaHei", "--prop", "size=18",
    "--prop", "color=64748b", "--prop", "x=8cm", "--prop", "y=13cm",
    "--prop", "width=12cm", "--prop", "height=1cm", "--prop", "fill=none")

print("  ✓ Slide 1 complete")

# ==================== SLIDE 2: STATEMENT ====================
print("\n
[S2] Building Statement Slide...")
helper("clone", OUTPUT, 1, 2)
helper("ghost", OUTPUT, 2, 4, 5, 6)  # Ghost title, subtitle, date

# Move scene actors
run("officecli", "set", OUTPUT, "/slide[2]/shape[1]", "--prop", "x=24cm", "--prop", "y=1cm")  # ring
run("officecli", "set", OUTPUT, "/slide[2]/shape[2]", "--prop", "x=4cm", "--prop", "y=15cm")  # dot
run("officecli", "set", OUTPUT, "/slide[2]/shape[3]", "--prop", "x=2cm", "--prop", "y=8cm")   # line

# Statement title
run("officecli", "add", OUTPUT, "/slide[2]", "--type", "shape",
    "--prop", "name=#s2-title", "--prop", "text=核心发现：这不是正常的预警方式",
    "--prop", "font=Microsoft YaHei", "--prop", "size=54", "--prop", "bold=true",
    "--prop", "color=ffffff", "--prop", "x=6cm", "--prop", "y=3cm",
    "--prop", "width=30cm", "--prop", "height=3cm", "--prop", "fill=none")

# Core judgment
run("officecli", "add", OUTPUT, "/slide[2]", "--type", "shape",
    "--prop", "name=#s2-judgment", "--prop", "text=表演型预警 + 转移视线 + 保护关系网",
    "--prop", "font=Microsoft YaHei", "--prop", "size=40", "--prop", "bold=true",
    "--prop", "color=60a5fa", "--prop", "x=6cm", "--prop", "y=6.5cm",
    "--prop", "width=30cm", "--prop", "height=2.5cm", "--prop", "fill=none")

# Core principles
principles = [
    "不接靶子 • 回归根本原因 • 保护安全感 • 用数据说话"
]
run("officecli", "add", OUTPUT, "/slide[2]", "--type", "shape",
    "--prop", "name=#s2-principles", "--prop", "text=" + principles[0],
    "--prop", "font=Microsoft YaHei", "--prop", "size=28",
    "--prop", "color=94a3b8", "--prop", "x=6cm", "--prop", "y=10cm",
    "--prop", "width=30cm", "--prop", "height=2cm", "--prop", "fill=none")

helper("verify", OUTPUT, 2)
print("  ✓ Slide 2 complete")

# ==================== SLIDE 3: PILLARS (4 columns) ====================
print("\n
[S3] Building Pillars Slide...")
helper("clone", OUTPUT, 2, 3)
helper("ghost", OUTPUT, 3, 4, 5, 6)  # Ghost content

# Move scene actors for variety
run("officecli", "set", OUTPUT, "/slide[3]/shape[1]", "--prop", "x=1cm", "--prop", "y=14cm")   # ring
run("officecli", "set", OUTPUT, "/slide[3]/shape[2]", "--prop", "x=30cm", "--prop", "y=2cm")   # dot
run("officecli", "set", OUTPUT, "/slide[3]/shape[3]", "--prop", "x=28cm", "--prop", "y=16cm")  # line

# Section title
run("officecli", "add", OUTPUT, "/slide[3]", "--type", "shape",
    "--prop", "name=#s3-title", "--prop", "text=行为模式拆解：四重组合拳",
    "--prop", "font=Microsoft YaHei", "--prop", "size=44", "--prop", "bold=true",
    "--prop", "color=ffffff", "--prop", "x=6cm", "--prop", "y=1.5cm",
    "--prop", "width=28cm", "--prop", "height=2.5cm", "--prop", "fill=none")

# Card backgrounds (pillars)
card_width = 7.5
start_x = 1.5
gap = 0.8
cards = [
    ("选择性攻击", "只攻击服务组
不攻击策略组", "保护刘伟佳
维护关系网", "f97316"),
    ("转移视线", "把交接期问题
转移到激励方案", "避开真正问题
规避交接责任", "ef4444"),
    ("道德绑架", "情绪化数字
1400工人5000家庭", "制造道德压力
逼迫表态", "8b5cf6"),
    ("群里放炮", "不私下沟通
直接在群聊表演", "破坏安全感
制造恐慌", "06b6d4")
]

for i, (title, subtitle, desc, color) in enumerate(cards):
    x = start_x + i * (card_width + gap)
    
    # Card background
