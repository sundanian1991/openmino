        "--prop", "width=6.5cm", "--prop", "height=2.5cm", "--prop", "fill=none")
    
    # Card description
    run("officecli", "add", OUTPUT, "/slide[3]", "--type", "shape",
        "--prop", f"name=#s3-desc{i+1}", "--prop", "text=" + desc,
        "--prop", "font=Microsoft YaHei", "--prop", "size=14",
        "--prop", "color=64748b", "--prop", f"x={x+0.5}cm", "--prop", "y=12.5cm",
        "--prop", "width=6.5cm", "--prop", "height=2.5cm", "--prop", "fill=none")

