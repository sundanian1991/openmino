{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Insight Asset OS",
  "version": "0.1.0",
  "identifier": "com.insightassetos.desktop",
  "build": {
    "frontendDist": "../src-tauri/loading-page",
    "devUrl": "http://localhost:3456",
    "beforeBuildCommand": "bash scripts/build-bundle.sh",
    "beforeDevCommand": ""
  },
  "app": {
    "windows": [
      {
        "title": "Insight Asset OS",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "app"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "../dist/standalone-bundle": "standalone-bundle/"
    }
  }
}
