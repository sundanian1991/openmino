    {
      "id": "quadrant1_desc",
      "type": "text",
      "x": 170,
      "y": 170,
      "width": 140,
      "height": 100,
      "text": "自身峰值比 >85%\n头部差距 >80%\n\n解读：自己发挥好，\n也跟得上头部\n\n动作：标杆分享",
      "fontSize": 13,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "fill": "#1e3a5f"
