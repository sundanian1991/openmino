{
  "description": "viz-design 标准测试用例 — 每个用例包含输入数据、期望模式、叙事角度、标杆配置",
  "version": "1.0",
  "cases": [
    {
      "id": "TC-01",
      "name": "排名类 — 水平柱状图",
      "input": {
        "description": "5 家供应商业绩达标率排名",
        "data": {
          "fields": ["supplier", "achievement_rate"],
          "rows": [
            {"supplier": "毅航", "achievement_rate": 95.2},
            {"supplier": "毛毛虫", "achievement_rate": 91.8},
            {"supplier": "伽玛", "achievement_rate": 87.3},
            {"supplier": "赛维斯", "achievement_rate": 82.1},
            {"supplier": "岐力", "achievement_rate": 76.5}
          ]
        }
      },
      "expected": {
        "pattern": "13-柱状图",
        "chartType": "bar_chart",
        "narrativeAngles": [
          {
            "angle": "highlight_top",
            "title": "毅航达标率领先 8.7 个百分点，岐力落后基准线",
            "highlight": ["毅航"],
            "echartsConfig": {"series[0].itemStyle.color": "WARM for 毅航, STONE for others", "series[0].markLine.data[0].yAxis": 85, "series[0].label.show": true}
          },
          {
            "angle": "highlight_bottom",
            "title": "岐力达标率不足 80%，需重点跟进",
            "highlight": ["岐力"],
            "echartsConfig": {"series[0].itemStyle.color": "WARM for 岐力, STONE for others", "series[0].markLine.data[0].yAxis": 80}
          },
          {
            "angle": "overview",
            "title": "5 家供应商达标率 76.5%-95.2%，整体稳健",
            "highlight": [],
            "echartsConfig": {"series[0].itemStyle.color": "gradient from WARM to STONE", "series[0].markLine.data[0].type": "average"}
          }
        ],
        "echartsKeys": {
          "yAxis.axisLine.show": false,
          "xAxis.splitLine.show": false,
          "animation": false
        }
      }
    },
    {
      "id": "TC-02",
      "name": "趋势类 — 折线图",
      "input": {
        "description": "毅航 12 个月业绩趋势",
        "data": {
          "fields": ["month", "achievement_rate"],
          "rows": [
            {"month": "1月", "achievement_rate": 88.1},
            {"month": "2月", "achievement_rate": 89.3},
            {"month": "3月", "achievement_rate": 91.2},
            {"month": "4月", "achievement_rate": 90.5},
            {"month": "5月", "achievement_rate": 92.8},
            {"month": "6月", "achievement_rate": 93.1},
            {"month": "7月", "achievement_rate": 91.7},
            {"month": "8月", "achievement_rate": 94.2},
            {"month": "9月", "achievement_rate": 95.2},
            {"month": "10月", "achievement_rate": 93.8},
            {"month": "11月", "achievement_rate": 96.1},
            {"month": "12月", "achievement_rate": 95.7}
          ]
        }
      },
      "expected": {
        "pattern": "07-折线图",
        "chartType": "line_chart",
        "narrativeAngles": [
          {
            "angle": "highlight_peak",
            "title": "11 月创下年度新高 96.1%，全年稳步上升",
            "highlight": ["11月"],
            "echartsConfig": {"series[0].markPoint.data[0].coord": ["11月", 96.1], "series[0].markLine.data[0].type": "average"}
          },
          {
            "angle": "highlight_trend",
            "title": "从 88.1% 到 95.7%，全年上行趋势明确",
            "highlight": ["1月", "12月"],
            "echartsConfig": {"series[0].markLine.data[0]": {"yAxis": 88.1}, "series[0].markLine.data[1]": {"yAxis": 95.7}}
          }
        ],
        "echartsKeys": {
          "smooth": true,
          "yAxis.axisLine.show": false,
          "xAxis.splitLine.show": false,
          "animation": false
        }
      }
    },
    {
      "id": "TC-03",
      "name": "多维对比 — 雷达图",
      "input": {
        "description": "3 家供应商 6 维度健康度对比",
        "data": {
          "fields": ["dimension", "supplier_A", "supplier_B", "supplier_C"],
          "rows": [
            {"dimension": "业绩达成", "supplier_A": 95, "supplier_B": 82, "supplier_C": 78},
            {"dimension": "质量控制", "supplier_A": 88, "supplier_B": 90, "supplier_C": 75},
            {"dimension": "人员稳定", "supplier_A": 92, "supplier_B": 76, "supplier_C": 80},
            {"dimension": "合规指标", "supplier_A": 85, "supplier_B": 88, "supplier_C": 82},
            {"dimension": "响应速度", "supplier_A": 90, "supplier_B": 72, "supplier_C": 88},
            {"dimension": "成本控制", "supplier_A": 78, "supplier_B": 85, "supplier_C": 90}
          ]
        }
      },
      "expected": {
        "pattern": "22-雷达图",
        "chartType": "radar",
        "narrativeAngles": [
          {
            "angle": "highlight_leader",
            "title": "供应商 A 综合领先，成本控制是唯一短板",
            "highlight": ["supplier_A"],
            "echartsConfig": {"series[0].lineStyle.color": "WARM", "series[0].areaStyle.color": "rgba(194,109,58,0.15)"}
          },
          {
            "angle": "compare_strengths",
            "title": "三供应商各有强项，互补空间大",
            "highlight": [],
            "echartsConfig": {"series[0].lineStyle.color": "WARM", "series[1].lineStyle.color": "STONE", "series[2].lineStyle.color": "TEAL"}
          }
        ],
        "echartsKeys": {
          "yAxis.axisLine.show": false,
          "animation": false
        }
      }
    },
    {
      "id": "TC-04",
      "name": "堆叠构成 — 堆叠柱状图",
      "input": {
        "description": "4 个季度 3 类收入构成",
        "data": {
          "fields": ["quarter", "product_A", "product_B", "product_C"],
          "rows": [
            {"quarter": "Q1", "product_A": 320, "product_B": 180, "product_C": 120},
            {"quarter": "Q2", "product_A": 350, "product_B": 210, "product_C": 140},
            {"quarter": "Q3", "product_A": 380, "product_B": 240, "product_C": 160},
            {"quarter": "Q4", "product_A": 410, "product_B": 260, "product_C": 180}
          ]
        }
      },
      "expected": {
        "pattern": "13-柱状图（堆叠）",
        "chartType": "stacked_bar",
        "narrativeAngles": [
          {
            "angle": "highlight_top_product",
            "title": "产品 A 贡献超 50%，Q4 总量突破 850 万",
            "highlight": ["product_A"],
            "echartsConfig": {"series[0].itemStyle.color": "WARM", "series[0].label.show": true}
          },
          {
            "angle": "highlight_growth",
            "title": "三类产品齐增长，Q4 环比增 9.2%",
            "highlight": [],
            "echartsConfig": {"series.forEach": "all 3 series show label on top"}
          }
        ],
        "echartsKeys": {
          "stack": "s",
          "yAxis.axisLine.show": false,
          "xAxis.splitLine.show": false,
          "animation": false
        }
      }
    },
    {
      "id": "TC-05",
      "name": "相关性 — 散点图",
      "input": {
        "description": "12 家供应商人效 vs 成本",
        "data": {
          "fields": ["supplier", "efficiency", "cost"],
          "rows": [
            {"supplier": "A", "efficiency": 92, "cost": 85},
            {"supplier": "B", "efficiency": 88, "cost": 72},
            {"supplier": "C", "efficiency": 78, "cost": 90},
            {"supplier": "D", "efficiency": 95, "cost": 80},
            {"supplier": "E", "efficiency": 70, "cost": 95},
            {"supplier": "F", "efficiency": 85, "cost": 78},
            {"supplier": "G", "efficiency": 82, "cost": 88},
            {"supplier": "H", "efficiency": 91, "cost": 75},
            {"supplier": "I", "efficiency": 73, "cost": 82},
            {"supplier": "J", "efficiency": 89, "cost": 70},
            {"supplier": "K", "efficiency": 76, "cost": 92},
            {"supplier": "L", "efficiency": 94, "cost": 68}
          ]
        }
      },
      "expected": {
        "pattern": "09-散点图",
        "chartType": "scatter",
        "narrativeAngles": [
          {
            "angle": "highlight_efficient",
            "title": "D、L 高效低成本，是标杆；E、C 低效高成本需整改",
            "highlight": ["D", "L"],
            "echartsConfig": {"series[0].markLine.data": [{"xAxis": 85}, {"yAxis": 80}], "series[0].markArea.data": [[{"xAxis":85,"yAxis":60},{"xAxis":100,"yAxis":85}]]}
          }
        ],
        "echartsKeys": {
          "markLine": true,
          "markArea": true,
          "symbolSize": 10,
          "yAxis.axisLine.show": false,
          "animation": false
        }
      }
    },
    {
      "id": "TC-06",
      "name": "占比 — 饼图",
      "input": {
        "description": "金条产线 3 类供应商占比",
        "data": {
          "fields": ["category", "percentage"],
          "rows": [
            {"category": "头部（6家）", "percentage": 65},
            {"category": "腰部（8家）", "percentage": 25},
            {"category": "尾部（5家）", "percentage": 10}
          ]
        }
      },
      "expected": {
        "pattern": "01-饼图",
        "chartType": "pie",
        "narrativeAngles": [
          {
            "angle": "highlight_dominance",
            "title": "头部 6 家贡献 65% 产能，集中度需关注",
            "highlight": ["头部（6家）"],
            "echartsConfig": {"series[0].itemStyle.color": "WARM for 头部, STONE for others", "series[0].label.formatter": "{b}: {d}%"}
          }
        ],
        "echartsKeys": {
          "radius": ["40%", "65%"],
          "center": ["50%", "55%"],
          "animation": false
        }
      }
    }
  ]
}
