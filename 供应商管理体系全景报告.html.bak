<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>供应商管理体系全景报告</title>
<script src="https://cdn.jsdelivr.net/npm/chart.js@4"></script>
<script src="https://cdn.jsdelivr.net/npm/chartjs-plugin-annotation@3"></script>
<style>
  :root {
    --bg: #ffffff;
    --card-bg: #f5f5f7;
    --text: #1d1d1f;
    --text-secondary: #86868b;
    --border: #d2d2d7;
    --accent: #0071e3;
    --accent-light: #e8f0fe;
    --green: #34c759;
    --orange: #ff9500;
    --red: #ff3b30;
    --purple: #af52de;
  }
  * { margin: 0; padding: 0; box-sizing: border-box; }
  body {
    font-family: -apple-system, 'SF Pro Display', 'Helvetica Neue', 'PingFang SC', sans-serif;
    color: var(--text);
    background: var(--bg);
    -webkit-font-smoothing: antialiased;
    line-height: 1.65;
  }
  .container { max-width: 1000px; margin: 0 auto; padding: 0 24px; }

  /* Hero */
  .hero {
    padding: 100px 0 60px;
    text-align: center;
  }
  .hero h1 {
    font-size: 48px;
    font-weight: 700;
    letter-spacing: -0.02em;
    margin-bottom: 16px;
    line-height: 1.1;
  }
  .hero .subtitle {
    font-size: 20px;
    color: var(--text-secondary);
    max-width: 600px;
    margin: 0 auto;
  }
  .hero .meta {
    margin-top: 24px;
    font-size: 13px;
    color: var(--text-secondary);
  }

  /* Section */
  .section { padding: 80px 0; }
  .section-title {
    font-size: 28px;
    font-weight: 600;
    margin-bottom: 8px;
    letter-spacing: -0.01em;
  }
  .section-desc {
    font-size: 17px;
    color: var(--text-secondary);
    margin-bottom: 40px;
    max-width: 700px;
  }

  /* Divider */
  .divider {
    height: 1px;
    background: var(--border);
    width: 100%;
  }

  /* Methodology Cards */
  .principle-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 16px;
  }
  .principle-card {
    background: var(--card-bg);
    border-radius: 16px;
    padding: 32px;
    transition: transform 0.2s;
  }
  .principle-card:hover { transform: translateY(-2px); }
  .principle-card .num {
    font-size: 13px;
    font-weight: 600;
    color: var(--accent);
    margin-bottom: 8px;
  }
  .principle-card h3 {
    font-size: 21px;
    font-weight: 600;
    margin-bottom: 12px;
    line-height: 1.3;
  }
  .principle-card p {
    font-size: 15px;
    color: var(--text-secondary);
    line-height: 1.6;
  }

  /* Scenario Grid */
  .scenario-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 16px;
  }
  .scenario-card {
    background: var(--card-bg);
    border-radius: 16px;
    padding: 24px;
  }
  .scenario-card .tag {
    display: inline-block;
    font-size: 11px;
    font-weight: 600;
    color: #fff;
    background: var(--accent);
    padding: 3px 10px;
    border-radius: 20px;
    margin-bottom: 10px;
  }
  .scenario-card h4 {
    font-size: 17px;
    font-weight: 600;
    margin-bottom: 8px;
  }
  .scenario-card .trigger {
    font-size: 13px;
    color: var(--text-secondary);
    margin-bottom: 8px;
  }
  .scenario-card .trigger strong { color: var(--text); }
  .scenario-card .actions {
    font-size: 13px;
    color: var(--text-secondary);
  }
  .scenario-card .actions strong { color: var(--text); }

  /* Chart Wrapper */
  .chart-wrapper {
    background: var(--card-bg);
    border-radius: 16px;
    padding: 32px;
    margin-bottom: 24px;
  }
  .chart-wrapper canvas {
    max-height: 420px;
    width: 100% !important;
  }
  .chart-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }
  .chart-row .chart-wrapper { margin-bottom: 0; }

  /* Insight Box */
  .insight-box {
    background: var(--accent-light);
    border-radius: 12px;
    padding: 20px 24px;
    margin-top: 16px;
  }
  .insight-box p {
    font-size: 15px;
    color: var(--text);
    line-height: 1.6;
  }
  .insight-box strong { color: var(--accent); }

  /* Quadrant */
  .quadrant-wrapper {
    background: var(--card-bg);
    border-radius: 16px;
    padding: 32px;
  }
  .quadrant-container {
    position: relative;
    width: 100%;
    max-width: 500px;
    margin: 0 auto;
    aspect-ratio: 1;
  }
  .quadrant-container canvas {
    width: 100% !important;
    height: 100% !important;
  }
  .quadrant-types {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 12px;
    margin-top: 24px;
  }
  .quadrant-type {
    background: var(--bg);
    border-radius: 12px;
    padding: 16px;
    text-align: center;
  }
  .quadrant-type .label {
    font-size: 15px;
    font-weight: 600;
    margin-bottom: 4px;
  }
  .quadrant-type .desc {
    font-size: 13px;
    color: var(--text-secondary);
  }
  .q-beacon { color: var(--green); }
  .q-striver { color: var(--orange); }
  .q-problem { color: var(--red); }
  .q-fluctuation { color: var(--purple); }

  /* Decision Auth Matrix */
  .auth-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 15px;
    background: var(--card-bg);
    border-radius: 16px;
    overflow: hidden;
  }
  .auth-table th {
    text-align: left;
    padding: 14px 20px;
    border-bottom: 2px solid var(--text);
    font-weight: 600;
    font-size: 13px;
    color: var(--text-secondary);
    background: var(--card-bg);
  }
  .auth-table td {
    padding: 14px 20px;
    border-bottom: 1px solid var(--border);
  }
  .auth-table tr:last-child td { border-bottom: none; }
  .auth-badge {
    display: inline-block;
    font-size: 12px;
    font-weight: 600;
    padding: 3px 12px;
    border-radius: 20px;
  }
  .auth-auto { background: #e8f0fe; color: var(--accent); }
  .auth-yiren { background: #fef2e8; color: var(--orange); }
  .auth-junge { background: #fce8e8; color: var(--red); }

  /* Footer */
  .footer {
    padding: 40px 0 60px;
    text-align: center;
  }
  .footer p {
    font-size: 12px;
    color: var(--text-secondary);
    line-height: 1.8;
  }

  /* Responsive */
  @media (max-width: 768px) {
    .hero { padding: 60px 0 40px; }
    .hero h1 { font-size: 32px; }
    .hero .subtitle { font-size: 17px; }
    .section { padding: 48px 0; }
    .section-title { font-size: 24px; }
    .principle-grid { grid-template-columns: 1fr; }
    .scenario-grid { grid-template-columns: 1fr; }
    .chart-row { grid-template-columns: 1fr; }
    .quadrant-types { grid-template-columns: 1fr; }
    .chart-wrapper { padding: 20px; }
    .chart-wrapper canvas { max-height: 300px; }
  }
</style>
</head>
<body>

<!-- Hero -->
<div class="hero">
  <div class="container">
    <h1>供应商管理体系全景报告</h1>
    <p class="subtitle">基于 8 场景管理框架与方法论，全景呈现供应商全生命周期管理的制度体系、分析工具与决策机制</p>
    <p class="meta">数据来源：场景手册 · 工具箱 v5.0 · 问题清单 · 看板系统 &nbsp;|&nbsp; 报告日期：2026-05-30</p>
  </div>
</div>

<div class="divider"></div>

<!-- 方法论核心 -->
<div class="section">
  <div class="container">
    <div class="principle-grid">
      <div class="principle-card">
        <div class="num">01</div>
        <h3>制度盯人，不人盯人</h3>
        <p>规则驱动，异常触发，正常不干预。用排名和阈值自动管理，不是每天巡检逐个点名。</p>
      </div>
      <div class="principle-card">
        <div class="num">02</div>
        <h3>引导式设问，不给答案</h3>
        <p>你提问，他回答，让供应商自己找到办法。不代替对方做归因，而是用问题引导思考。</p>
      </div>
      <div class="principle-card">
        <div class="num">03</div>
        <h3>数据说话，用数据讲故事</h3>
        <p>不是摆数据，而是让数据自动说出结论。每个汇报都设计成让领导层十秒听懂的故事。</p>
      </div>
      <div class="principle-card">
        <div class="num">04</div>
        <h3>双维度交叉，多维度验证</h3>
        <p>不只从一个角度看问题，交叉验证避免误判。产能利用率用自身峰值比 + 头部差距双维度。</p>
      </div>
    </div>
  </div>
</div>

<div class="divider"></div>

<!-- 八场景管理体系 -->
<div class="section">
  <div class="container">
    <h2 class="section-title">八场景管理体系</h2>
    <p class="section-desc">供应商全生命周期 8 大管理场景，每个场景从触发条件到核心动作形成闭环</p>
    <div class="scenario-grid">
      <div class="scenario-card">
        <span class="tag">整改</span>
        <h4>KPI 不达标整改</h4>
        <p class="trigger"><strong>触发条件：</strong>连续 1-3 个月不达标</p>
        <p class="actions"><strong>核心动作：</strong>数据确认 → 原因诊断 → 整改要求 → 跟踪验证</p>
      </div>
      <div class="scenario-card">
        <span class="tag" style="background:var(--orange);">博弈</span>
        <h4>供应商"绑架"应对</h4>
        <p class="trigger"><strong>触发条件：</strong>头部供应商议价/威胁退出</p>
        <p class="actions"><strong>核心动作：</strong>判断真假 → 准备筹码 → 谈判底线 → 渐进替换</p>
      </div>
      <div class="scenario-card">
        <span class="tag" style="background:var(--purple);">调整</span>
        <h4>份额调整</h4>
        <p class="trigger"><strong>触发条件：</strong>赛马结果出炉</p>
        <p class="actions"><strong>核心动作：</strong>数据确认 → 方案制定 → 内部对齐 → 供应商沟通</p>
      </div>
      <div class="scenario-card">
        <span class="tag" style="background:var(--green);">准入</span>
        <h4>新供应商准入</h4>
        <p class="trigger"><strong>触发条件：</strong>新供应商申请</p>
        <p class="actions"><strong>核心动作：</strong>资料审核 → 现场考察 → 试单评估 → 合同谈判</p>
      </div>
      <div class="scenario-card">
        <span class="tag" style="background:var(--red);">退出</span>
        <h4>清退决策与执行</h4>
        <p class="trigger"><strong>触发条件：</strong>连续 3 月不达标/重大违规</p>
        <p class="actions"><strong>核心动作：</strong>清退决策 → 替代方案 → 供应商沟通 → 交接执行</p>
      </div>
      <div class="scenario-card">
        <span class="tag" style="background:var(--orange);">议价</span>
        <h4>突然提价应对</h4>
        <p class="trigger"><strong>触发条件：</strong>供应商提出涨价</p>
        <p class="actions"><strong>核心动作：</strong>了解原因 → 判断合理性 → 谈判筹码 → 达成共识</p>
      </div>
      <div class="scenario-card">
        <span class="tag" style="background:var(--purple);">人力</span>
        <h4>人员流失应对</h4>
        <p class="trigger"><strong>触发条件：</strong>流失率 &gt;10%/月</p>
        <p class="actions"><strong>核心动作：</strong>归因分析 → 影响评估 → 干预措施 → 替代方案</p>
      </div>
      <div class="scenario-card">
        <span class="tag" style="background:var(--red);">质量</span>
        <h4>质量下滑应对</h4>
        <p class="trigger"><strong>触发条件：</strong>投诉率增长 &gt;20%/转化率下降 &gt;10%</p>
        <p class="actions"><strong>核心动作：</strong>问题确认 → 原因诊断 → 整改要求 → 熔断机制</p>
      </div>
    </div>
  </div>
</div>

<div class="divider"></div>

<!-- 管理风格对比 -->
<div class="section">
  <div class="container">
    <h2 class="section-title">两种管理哲学对比</h2>
    <p class="section-desc">年老师的制度驱动体系 vs 刘乾坤的人盯人模式，在六个关键维度上的能力分布</p>
    <div class="chart-wrapper">
      <canvas id="radarComparison"></canvas>
    </div>
    <div class="insight-box">
      <p><strong>核心洞察：</strong>两种模式并非优劣之分，而是适用阶段之别。年老师体系以 4-6 小时/月的投入覆盖 30-40 小时/月的管理效果，核心差异在于"体系化程度"和"可持续性"。刘乾坤模式的优势在于过程控制和细节把控，适合小规模、高变动环境。</p>
    </div>
  </div>
</div>

<div class="divider"></div>

<!-- 产能利用率双维度 -->
<div class="section">
  <div class="container">
    <h2 class="section-title">产能利用率双维度矩阵</h2>
    <p class="section-desc">工具核心创新：不用行业均值作分母，用"自身峰值比"和"头部差距"双维度交叉定位</p>
    <div class="chart-wrapper">
      <canvas id="quadrantChart"></canvas>
    </div>
    <div class="quadrant-types">
      <div class="quadrant-type">
        <div class="label q-beacon">标杆型</div>
        <div class="desc">自身峰值比高 · 头部差距小<br>双高标杆，可作为管理范本</div>
      </div>
      <div class="quadrant-type">
        <div class="label q-striver">尽力型</div>
        <div class="desc">自身峰值比高 · 头部差距大<br>已发挥自身水平，需拉高上限</div>
      </div>
      <div class="quadrant-type">
        <div class="label q-problem">问题型</div>
        <div class="desc">自身峰值比低 · 头部差距大<br>双低，需深度干预</div>
      </div>
      <div class="quadrant-type">
        <div class="label q-fluctuation">暂时波动</div>
        <div class="desc">自身峰值比低 · 头部差距小<br>短期波动，观察为主</div>
      </div>
    </div>
    <div class="insight-box" style="margin-top:16px;">
      <p><strong>关键修正：</strong>人均 GMV 基于<strong>熟手人数</strong>计算，非总人数。新人占比 &gt;30% 时强制使用熟手人均 GMV，避免"供应商招了很多新人导致人均被稀释"误判为管理问题。</p>
    </div>
  </div>
</div>

<div class="divider"></div>

<!-- 主管胜任评估 + 数据质量 -->
<div class="section">
  <div class="container">
    <h2 class="section-title">主管胜任评估</h2>
    <p class="section-desc">5 项可观察指标，达标 ≤2 项为不胜任信号</p>
    <div class="chart-row">
      <div class="chart-wrapper">
        <canvas id="supervisorRadar"></canvas>
      </div>
      <div class="chart-wrapper">
        <canvas id="dataQuality"></canvas>
        <div style="text-align:center; margin-top:12px; font-size:13px; color:var(--text-secondary);">
          0 项触发 = 100 分 &nbsp;·&nbsp; 1 项 = 70 分 &nbsp;·&nbsp; 2 项以上 = 40 分（排名加注星号，不作为奖惩依据）
        </div>
      </div>
    </div>
  </div>
</div>

<div class="divider"></div>

<!-- 决策授权矩阵 -->
<div class="section">
  <div class="container">
    <h2 class="section-title">决策授权矩阵</h2>
    <p class="section-desc">明确年老师在每个动作上的权限边界——日常管理独立完成，核心利益走授权链</p>
    <table class="auth-table">
      <thead>
        <tr>
          <th>权限级别</th>
          <th>可执行动作</th>
          <th>原则</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td><span class="auth-badge auth-auto">自主执行</span></td>
          <td>月度排名、首次预警、正式约谈</td>
          <td style="color:var(--text-secondary); font-size:13px;">日常管理独立完成，无需请示</td>
        </tr>
        <tr>
          <td><span class="auth-badge auth-yiren">需易人哥确认</span></td>
          <td>要求更换主管、清退评估启动、约谈供应商高层</td>
          <td style="color:var(--text-secondary); font-size:13px;">不是"请示"，是"对齐"</td>
        </tr>
        <tr>
          <td><span class="auth-badge auth-junge">需军哥确认</span></td>
          <td>清退事前沟通、诚信红线约谈事前报备</td>
          <td style="color:var(--text-secondary); font-size:13px;">触及核心利益必须走授权链</td>
        </tr>
      </tbody>
    </table>
  </div>
</div>

<div class="divider"></div>

<!-- Footer -->
<div class="footer">
  <div class="container">
    <p>数据来源：场景手册 · 供应商管理工具箱 v5.0 · 供应商管理看板 · 问题清单 · 问题状态更新表</p>
    <p>本报告基于内部方法论文档整理，所有分析框架和数据指标来自实际管理实践</p>
    <p style="margin-top:8px;">供应商管理场景与方法论 · Mino 出品 · 2026-05-30</p>
  </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
  if (typeof ChartAnnotation !== 'undefined') {
    Chart.register(ChartAnnotation);
  }
  Chart.defaults.color = '#86868b';
  Chart.defaults.borderColor = '#e5e5e5';
  Chart.defaults.font.family = "-apple-system, 'SF Pro Display', 'PingFang SC', sans-serif";

  // ====== 1. 管理风格雷达图 ======
  new Chart(document.getElementById('radarComparison'), {
    type: 'radar',
    data: {
      labels: ['管理效率', '体系化程度', '过程控制', '响应敏捷', '可持续性', '细节把控'],
      datasets: [{
        label: '年老师',
        data: [95, 95, 40, 60, 95, 30],
        borderColor: '#0071e3',
        backgroundColor: 'rgba(0, 113, 227, 0.08)',
        borderWidth: 2,
        pointRadius: 4,
        pointBackgroundColor: '#0071e3'
      }, {
        label: '刘乾坤',
        data: [30, 20, 90, 85, 25, 85],
        borderColor: '#86868b',
        backgroundColor: 'rgba(134, 134, 139, 0.08)',
        borderWidth: 2,
        pointRadius: 4,
        pointBackgroundColor: '#86868b'
      }]
    },
    options: {
      responsive: true,
      plugins: {
        legend: {
          position: 'bottom',
          labels: { usePointStyle: true, padding: 24, font: { size: 14 } }
        }
      },
      scales: {
        r: {
          beginAtZero: true,
          max: 100,
          ticks: { stepSize: 25, font: { size: 12 }, backdropColor: 'transparent' },
          grid: { color: '#e5e5e5' },
          angleLines: { color: '#e5e5e5' },
          pointLabels: { font: { size: 13, weight: '600' }, color: '#1d1d1f' }
        }
      }
    }
  });

  // ====== 2. 产能利用率双维度象限 (Scatter + Annotation) ======
  new Chart(document.getElementById('quadrantChart'), {
    type: 'scatter',
    data: {
      datasets: [{
        label: '标杆型',
        data: [{ x: 85, y: 88 }, { x: 78, y: 82 }],
        backgroundColor: '#34c759',
        borderColor: '#34c759',
        pointRadius: 8,
        pointBorderWidth: 0
      }, {
        label: '尽力型',
        data: [{ x: 82, y: 28 }, { x: 75, y: 35 }],
        backgroundColor: '#ff9500',
        borderColor: '#ff9500',
        pointRadius: 8,
        pointBorderWidth: 0
      }, {
        label: '问题型',
        data: [{ x: 22, y: 25 }],
        backgroundColor: '#ff3b30',
        borderColor: '#ff3b30',
        pointRadius: 8,
        pointBorderWidth: 0
      }, {
        label: '暂时波动',
        data: [{ x: 30, y: 80 }, { x: 35, y: 72 }],
        backgroundColor: '#af52de',
        borderColor: '#af52de',
        pointRadius: 8,
        pointBorderWidth: 0
      }]
    },
    options: {
      responsive: true,
      plugins: {
        legend: {
          position: 'bottom',
          labels: { usePointStyle: true, padding: 20, font: { size: 13 } }
        },
        annotation: {
          annotations: {
            lineX: {
              type: 'line',
              xMin: 50, xMax: 50,
              borderColor: '#d2d2d7',
              borderWidth: 1,
              borderDash: [6, 4],
              label: {
                display: true,
                content: '自身峰值比 50%',
                position: 'start',
                font: { size: 11, weight: '400' },
                color: '#86868b',
                yAdjust: -8
              }
            },
            lineY: {
              type: 'line',
              yMin: 50, yMax: 50,
              borderColor: '#d2d2d7',
              borderWidth: 1,
              borderDash: [6, 4],
              label: {
                display: true,
                content: '头部差距 50%',
                position: 'start',
                font: { size: 11, weight: '400' },
                color: '#86868b',
                xAdjust: 8
              }
            }
          }
        }
      },
      scales: {
        x: {
          type: 'linear',
          position: 'bottom',
          min: 0, max: 100,
          title: {
            display: true,
            text: '自身峰值比（越高越好）',
            font: { size: 13, weight: '600' },
            color: '#1d1d1f'
          },
          ticks: { stepSize: 25, font: { size: 12 } },
          grid: { color: '#e5e5e5' }
        },
        y: {
          min: 0, max: 100,
          title: {
            display: true,
            text: '头部差距（越小越接近第一）',
            font: { size: 13, weight: '600' },
            color: '#1d1d1f'
          },
          ticks: { stepSize: 25, font: { size: 12 } },
          grid: { color: '#e5e5e5' }
        }
      }
    }
  });

  // ====== 3. 主管胜任评估雷达图 ======
  new Chart(document.getElementById('supervisorRadar'), {
    type: 'radar',
    data: {
      labels: ['团队稳定度\n(流失率<8%)', '出勤稳定度\n(>90%)', '人效趋势\n(不连降2月)', '响应质量\n(48h回复>80%)', '整改执行力\n(按期>70%)'],
      datasets: [{
        label: '达标阈值',
        data: [60, 60, 60, 60, 60],
        borderColor: '#ff9500',
        backgroundColor: 'rgba(255, 149, 0, 0.05)',
        borderWidth: 2,
        borderDash: [5, 5],
        pointRadius: 0,
        pointHitRadius: 0
      }, {
        label: '合格供应商',
        data: [85, 92, 70, 78, 65],
        borderColor: '#0071e3',
        backgroundColor: 'rgba(0, 113, 227, 0.08)',
        borderWidth: 2,
        pointRadius: 4,
        pointBackgroundColor: '#0071e3'
      }]
    },
    options: {
      responsive: true,
      plugins: {
        legend: {
          position: 'bottom',
          labels: { usePointStyle: true, padding: 20, font: { size: 13 } }
        }
      },
      scales: {
        r: {
          beginAtZero: true,
          max: 100,
          ticks: { stepSize: 20, font: { size: 11 }, backdropColor: 'transparent' },
          grid: { color: '#e5e5e5' },
          angleLines: { color: '#e5e5e5' },
          pointLabels: { font: { size: 12, weight: '500' }, color: '#1d1d1f' }
        }
      }
    }
  });

  // ====== 4. 数据质量分 ======
  new Chart(document.getElementById('dataQuality'), {
    type: 'bar',
    data: {
      labels: ['出勤率\n过于平滑', '离职率\n连续为零', 'GMV波动\n过小', '熟手人数\n突增', '考核节点\n前后突变'],
      datasets: [{
        label: '触发次数',
        data: [0, 0, 1, 2, 1],
        backgroundColor: ['#34c759', '#34c759', '#ff9500', '#ff3b30', '#ff9500'],
        borderRadius: 6,
        borderSkipped: false
      }]
    },
    options: {
      responsive: true,
      plugins: {
        legend: { display: false },
        title: {
          display: true,
          text: '数据质量信号检测',
          font: { size: 15, weight: '600' },
          color: '#1d1d1f',
          padding: { bottom: 16 }
        }
      },
      scales: {
        y: {
          beginAtZero: true,
          max: 5,
          ticks: { stepSize: 1, font: { size: 11 } },
          grid: { color: '#e5e5e5' },
          title: {
            display: true,
            text: '月触发次数',
            font: { size: 12 },
            color: '#86868b'
          }
        },
        x: {
          grid: { display: false },
          ticks: { font: { size: 11 } }
        }
      }
    }
  });
});
</script>
</body>
</html>
