{
  "workspaceType": "general",
  "organizationStyle": "mixed",
  "captureDefault": "memory/active/daily/（事实记录）或 workspace/（临时草稿）",
  "archivePolicy": {
    "completedTaskArchiveAfterDays": 30,
    "closedProjectArchive": true,
    "dailyMemoryRetentionDays": 30
  },
  "ignore": [
    ".obsidian/**",
    ".trash/**",
    "**/*.png",
    "**/*.jpg",
    "**/*.jpeg",
    "**/*.gif",
    "**/*.mp4",
    "node_modules/**",
    ".git/**"
  ],
  "index": {
    "maxFileSizeKB": 512,
    "chunkSize": 1200,
    "chunkOverlap": 150,
    "maxDepth": 8,
    "includeExtensions": [
      ".md",
      ".txt",
      ".markdown"
    ]
  }
}
