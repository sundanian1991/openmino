{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "sequential-thinking": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-sequential-thinking"],
      "enabled": true
    },
    "github": {
      "type": "local",
      "command": [
        "/Users/sundanian/.nvm/versions/node/v22.19.0/bin/npx",
        "-y",
        "@modelcontextprotocol/server-github"
      ],
      "environment": {
        "GITHUB_TOKEN": "{env:GITHUB_TOKEN}"
      },
      "enabled": true
    },
    "getnote": {
      "type": "local",
      "command": [
        "node",
        "/Users/sundanian/Documents/projects/ai-agents/my-agent/projects/mcp-servers/getnote/src/index.js"
      ],
      "environment": {
        "GETNOTE_AUTH_TOKEN": "{env:GETNOTE_AUTH_TOKEN}",
        "GETNOTE_CLIENT_ID": "{env:GETNOTE_CLIENT_ID}"
      },
      "enabled": true
    },
    "tavily": {
      "type": "local",
      "command": ["npx", "-y", "@tavily/mcp"],
      "environment": {
        "TAVILY_API_KEY": "{env:TAVILY_API_KEY}"
      },
      "enabled": true
    },
    "kaas-knowledge": {
      "type": "remote",
      "url": "https://ai-analysis-api.jd.com/mcp/",
      "enabled": true
    }
  }
}
